<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OkPlayer.App.Views.VolumeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Resting = speaker icon + a 4px level wick. On hover/focus a floating Acrylic capsule with the full
         slider rises above it (design "Volume" v3), so the OSC row never reflows. -->
    <Grid x:Name="Root" Background="Transparent" PointerEntered="OnRootEnter" PointerExited="OnRootExit">
        <StackPanel Spacing="3" VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- AllowFocusOnInteraction=False: a mouse click must NOT trap keyboard focus on the speaker, or its
                 OnKeyDown would keep eating Left/Right as volume and the player's seek would stop working until
                 focus moved. Tab/programmatic focus still works, so the keyboard-parity (focus → arrows adjust). -->
            <Button x:Name="SpeakerBtn" Width="34" Height="34" Padding="0" Click="OnMuteClick"
                    AllowFocusOnInteraction="False"
                    GotFocus="OnFocusGot" LostFocus="OnFocusLost" KeyDown="OnKeyDown"
                    Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Mute (M) &#x00B7; Ctrl-click: 100%">
                <FontIcon x:Name="SpeakerIcon" Glyph="&#xE767;" FontSize="18" Foreground="White" />
            </Button>
            <Grid Width="18" Height="3" Margin="0,-3,0,0">
                <Border Background="#30FFFFFF" CornerRadius="2" />
                <Border x:Name="Wick" Background="{ThemeResource OkOverVideoAccentBrush}" CornerRadius="2" HorizontalAlignment="Left" Width="14" />
            </Grid>
        </StackPanel>

        <Popup x:Name="Capsule" IsLightDismissEnabled="False">
            <Border x:Name="CapsuleBorder" PointerEntered="OnCapsuleEnter" PointerExited="OnRootExit" Opacity="0"
                    Background="#E6161619" CornerRadius="11" Padding="14,9" BorderThickness="1" BorderBrush="#22FFFFFF">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="CapsuleXform" TranslateY="6" ScaleX="0.96" ScaleY="0.96" />
                </Border.RenderTransform>
                <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center">
                    <Canvas x:Name="Track" Width="96" Height="14" Background="Transparent"
                            PointerPressed="OnTrackPressed" PointerMoved="OnTrackMoved" PointerReleased="OnTrackReleased">
                        <Border Canvas.Top="4" Width="96" Height="6" CornerRadius="3" Background="#33FFFFFF" />
                        <Border x:Name="TealFill" Canvas.Top="4" Canvas.Left="0" Height="6" CornerRadius="3" Background="{ThemeResource OkOverVideoAccentBrush}" />
                        <Border x:Name="AmberFill" Canvas.Top="4" Height="6" Background="#FFF0B840" Visibility="Collapsed" />
                        <Border x:Name="Marker" Canvas.Top="1" Width="2" Height="12" CornerRadius="1" Background="#80FFFFFF" />
                        <Border x:Name="Thumb" Canvas.Top="0" Width="14" Height="14" CornerRadius="7" Background="White">
                            <Border.Shadow><ThemeShadow /></Border.Shadow>
                        </Border>
                    </Canvas>
                    <TextBlock x:Name="Readout" Text="100%" FontSize="12" FontWeight="SemiBold" Foreground="White"
                               MinWidth="42" TextAlignment="Right" VerticalAlignment="Center" Tapped="OnReadoutTapped"
                               ToolTipService.ToolTip="Click to type an exact value" />
                    <TextBox x:Name="ReadoutInput" Width="46" Visibility="Collapsed" VerticalAlignment="Center"
                             FontSize="12" KeyDown="OnReadoutKey" LostFocus="OnReadoutLostFocus" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
