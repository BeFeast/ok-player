<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OkPlayer.App.Views.PlayerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:render="using:OkPlayer.Render"
    xmlns:ctl="using:OkPlayer.App.Controls"
    xmlns:vm="using:OkPlayer.App.ViewModels"
    IsTabStop="True">

    <UserControl.Resources>
        <Storyboard x:Name="ChromeShowSb">
            <DoubleAnimation Storyboard.TargetName="BottomChrome" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="BottomTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TitleChrome" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="TitleTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="ChromeHideSb">
            <DoubleAnimation Storyboard.TargetName="BottomChrome" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="BottomTransform" Storyboard.TargetProperty="Y" To="16" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TitleChrome" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="TitleTransform" Storyboard.TargetProperty="Y" To="-10" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="ToastShowSb">
            <DoubleAnimation Storyboard.TargetName="ToastHost" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetName="ToastTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="ToastHideSb">
            <DoubleAnimation Storyboard.TargetName="ToastHost" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25" />
        </Storyboard>
        <Storyboard x:Name="PanelShowSb">
            <DoubleAnimation Storyboard.TargetName="ChaptersPanel" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" />
            <DoubleAnimation Storyboard.TargetName="PanelTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="PanelHideSb">
            <DoubleAnimation Storyboard.TargetName="ChaptersPanel" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
            <DoubleAnimation Storyboard.TargetName="PanelTransform" Storyboard.TargetProperty="X" To="316" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="#FF050505" AllowDrop="True"
          KeyboardAcceleratorPlacementMode="Hidden"
          PointerMoved="OnRootPointerMoved" PointerPressed="OnRootPointerPressed"
          DragOver="OnDragOver" Drop="OnDrop">

        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="O" Invoked="OnOpenAccelerator" />
        </Grid.KeyboardAccelerators>

        <!-- the single video plane -->
        <render:MpvVideoPanel x:Name="Video" Tapped="OnVideoTapped" />

        <!-- minimal empty state shown until media is loaded -->
        <StackPanel x:Name="EmptyHint" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="6" IsHitTestVisible="False">
            <FontIcon Glyph="&#xE8E5;" FontSize="30" Foreground="#59FFFFFF" />
            <TextBlock Text="Open a file" HorizontalAlignment="Center" Foreground="#B3FFFFFF" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Text="Ctrl+O, or drop a video here" HorizontalAlignment="Center" Foreground="#80FFFFFF" FontSize="12.5" />
        </StackPanel>

        <!-- ===== top chrome: scrim + title ===== -->
        <Grid x:Name="TitleChrome" VerticalAlignment="Top" Height="42" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="TitleTransform" Y="-10" /></Grid.RenderTransform>
            <Border Background="{StaticResource OkTopScrimBrush}" IsHitTestVisible="False" />
            <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center" Margin="14,0">
                <FontIcon Glyph="&#xE768;" FontSize="13" Foreground="#E6FFFFFF" />
                <TextBlock x:Name="TitleText" Text="{x:Bind Vm.MediaTitle, Mode=OneWay}"
                           Foreground="#F2FFFFFF" FontSize="12.5" FontWeight="Medium" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ===== bottom chrome: scrim + OSC pill ===== -->
        <Grid x:Name="BottomChrome" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="BottomTransform" Y="16" /></Grid.RenderTransform>

            <!-- bottom scrim -->
            <Border VerticalAlignment="Bottom" Height="220" IsHitTestVisible="False"
                    Background="{StaticResource OkBottomScrimBrush}" />

            <!-- OSC pill -->
            <Border VerticalAlignment="Bottom" Margin="16" Padding="14,9" CornerRadius="16"
                    Background="{StaticResource OkOverVideoFillBrush}" BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource OkOverVideoHairlineBrush}">
                <Border.Shadow><ThemeShadow /></Border.Shadow>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- left cluster -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Style="{StaticResource OkOscIconButtonStyle}" FontSize="22"
                                Content="{x:Bind Vm.PlayPauseGlyph, Mode=OneWay}" Click="OnPlayClick"
                                ToolTipService.ToolTip="Play / Pause (Space)" />
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE892;" FontSize="16"
                                Click="OnPrevClick" ToolTipService.ToolTip="Previous chapter" />
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE893;" FontSize="16"
                                Click="OnNextClick" ToolTipService.ToolTip="Next chapter" />
                        <TextBlock Text="{x:Bind Vm.CurrentTimeText, Mode=OneWay}" Margin="6,0,2,0"
                                   VerticalAlignment="Center" Foreground="#CCFFFFFF" FontSize="11.5" FontWeight="Medium" />
                    </StackPanel>

                    <!-- seekbar -->
                    <ctl:SeekBar x:Name="Seek" Grid.Column="1" VerticalAlignment="Center"
                                 Fraction="{x:Bind Vm.PositionFraction, Mode=OneWay}" />

                    <!-- right cluster -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind Vm.TrailingTimeText, Mode=OneWay}" Margin="2,0,8,0"
                                   VerticalAlignment="Center" Foreground="#CCFFFFFF" FontSize="11.5" FontWeight="Medium"
                                   Tapped="OnTrailingTimeTapped" />
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="{x:Bind Vm.VolumeGlyph, Mode=OneWay}"
                                ToolTipService.ToolTip="Volume">
                            <Button.Flyout>
                                <Flyout FlyoutPresenterStyle="{StaticResource OkPopoverFlyoutStyle}" Placement="Top" Opened="OnVolumeFlyoutOpened">
                                    <Grid Width="186" Padding="4" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                                        <Button Grid.Column="0" Style="{StaticResource OkSwitcherRowStyle}" Padding="6"
                                                FontFamily="Segoe Fluent Icons" FontSize="16" Content="{x:Bind Vm.VolumeGlyph, Mode=OneWay}"
                                                Click="OnVolumeMuteClick" ToolTipService.ToolTip="Mute (M)" />
                                        <Slider x:Name="VolumeSlider" Grid.Column="1" Minimum="0" Maximum="130" StepFrequency="1"
                                                VerticalAlignment="Center" ValueChanged="OnVolumeSliderChanged" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Vm.VolumeText, Mode=OneWay}" VerticalAlignment="Center"
                                                   MinWidth="38" TextAlignment="Right" Style="{StaticResource OkSmallTextStyle}" />
                                    </Grid>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <!-- speed -->
                        <Button x:Name="SpeedChip" Style="{StaticResource OkSpeedChipStyle}" Margin="4,0"
                                Content="{x:Bind Vm.SpeedText, Mode=OneWay}" ToolTipService.ToolTip="Playback speed">
                            <Button.Flyout>
                                <Flyout FlyoutPresenterStyle="{StaticResource OkPopoverFlyoutStyle}" Placement="Top">
                                    <StackPanel Width="120">
                                        <TextBlock Text="Speed" Style="{StaticResource OkBodyStrongTextStyle}" Margin="6,4" />
                                        <Button Style="{StaticResource OkSwitcherRowStyle}" Tag="0.5"  Content="0.5&#x00D7;"  Click="OnSpeedStepClick" />
                                        <Button Style="{StaticResource OkSwitcherRowStyle}" Tag="0.75" Content="0.75&#x00D7;" Click="OnSpeedStepClick" />
                                        <Button Style="{StaticResource OkSwitcherRowStyle}" Tag="1.0"  Content="1.0&#x00D7;"  Click="OnSpeedStepClick" />
                                        <Button Style="{StaticResource OkSwitcherRowStyle}" Tag="1.25" Content="1.25&#x00D7;" Click="OnSpeedStepClick" />
                                        <Button Style="{StaticResource OkSwitcherRowStyle}" Tag="1.5"  Content="1.5&#x00D7;"  Click="OnSpeedStepClick" />
                                        <Button Style="{StaticResource OkSwitcherRowStyle}" Tag="2.0"  Content="2.0&#x00D7;"  Click="OnSpeedStepClick" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!-- subtitles -->
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE7F0;" ToolTipService.ToolTip="Subtitles">
                            <Button.Flyout>
                                <Flyout FlyoutPresenterStyle="{StaticResource OkPopoverFlyoutStyle}" Placement="Top">
                                    <StackPanel Width="272">
                                        <TextBlock Text="Subtitles" Style="{StaticResource OkBodyStrongTextStyle}" Margin="6,4" />
                                        <Button Style="{StaticResource OkSwitcherRowStyle}" Content="Off" Click="OnSubtitleOffClick" />
                                        <ItemsControl ItemsSource="{x:Bind Vm.SubtitleTracks, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:TrackInfo">
                                                    <Button Style="{StaticResource OkSwitcherRowStyle}" Content="{x:Bind Label}" Click="OnSubtitleTrackClick" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Border Height="1" Margin="8,4" Background="{ThemeResource OkStrokeBrush}" />
                                        <Button Style="{StaticResource OkSwitcherRowStyle}" IsEnabled="False"
                                                Foreground="{ThemeResource OkAccentTextBrush}" Content="Generate subtitles&#x2026;  (Scribe)" />
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,6,10,4">
                                            <TextBlock Text="Delay" VerticalAlignment="Center" FontSize="12.5" Foreground="{ThemeResource OkTextSecondaryBrush}" />
                                            <Button Style="{StaticResource OkSwitcherRowStyle}" Padding="9,3" FontFamily="Segoe UI" FontSize="14" Content="-" Click="OnSubDelayMinus" />
                                            <TextBlock Text="{x:Bind Vm.SubDelayText, Mode=OneWay}" VerticalAlignment="Center" MinWidth="56" TextAlignment="Center"
                                                       FontSize="12.5" FontWeight="SemiBold" Foreground="{ThemeResource OkAccentTextBrush}" />
                                            <Button Style="{StaticResource OkSwitcherRowStyle}" Padding="9,3" FontFamily="Segoe UI" FontSize="14" Content="+" Click="OnSubDelayPlus" />
                                        </StackPanel>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!-- audio -->
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE8D6;" ToolTipService.ToolTip="Audio">
                            <Button.Flyout>
                                <Flyout FlyoutPresenterStyle="{StaticResource OkPopoverFlyoutStyle}" Placement="Top">
                                    <StackPanel Width="272">
                                        <TextBlock Text="Audio" Style="{StaticResource OkBodyStrongTextStyle}" Margin="6,4" />
                                        <ItemsControl ItemsSource="{x:Bind Vm.AudioTracks, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:TrackInfo">
                                                    <Button Style="{StaticResource OkSwitcherRowStyle}" Content="{x:Bind Label}" Click="OnAudioTrackClick" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <Button x:Name="ChaptersButton" Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE8FD;"
                                Click="OnChaptersClick" ToolTipService.ToolTip="Chapters (C)" />
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE722;"
                                Click="OnScreenshotClick" ToolTipService.ToolTip="Screenshot (S)" />
                        <Button x:Name="FullscreenButton" Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE740;"
                                Click="OnFullscreenClick" ToolTipService.ToolTip="Fullscreen (F)" />
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE712;" ToolTipService.ToolTip="More">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Open file..." Click="OnOpenFromMenu" />
                                    <MenuFlyoutItem Text="A-B loop" Click="OnAbLoopClick" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Playlist / Queue" IsEnabled="False" />
                                    <MenuFlyoutItem Text="Video / Geometry" IsEnabled="False" />
                                    <MenuFlyoutItem Text="Mini-player" IsEnabled="False" />
                                    <MenuFlyoutItem Text="Settings..." IsEnabled="False" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== seek hover frame-preview ===== -->
        <Border x:Name="PreviewPanel" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                Margin="0,0,0,84" Opacity="0" IsHitTestVisible="False"
                Background="#F00C0C0C" CornerRadius="9" Padding="5,5,5,4"
                BorderThickness="1" BorderBrush="#26FFFFFF">
            <Border.RenderTransform><TranslateTransform x:Name="PreviewTransform" /></Border.RenderTransform>
            <StackPanel Spacing="4">
                <Border x:Name="PreviewImageFrame" Width="168" Height="94" CornerRadius="5"
                        Background="#FF000000" Visibility="Collapsed">
                    <Image x:Name="PreviewImage" Stretch="UniformToFill" />
                </Border>
                <TextBlock x:Name="PreviewTime" Text="0:00" HorizontalAlignment="Center"
                           Foreground="#F2FFFFFF" FontSize="12" FontWeight="SemiBold" />
            </StackPanel>
        </Border>

        <!-- ===== right-docked Chapters panel (slide-in Mica) ===== -->
        <Grid x:Name="ChaptersPanel" HorizontalAlignment="Right" Width="316" Opacity="0" Visibility="Collapsed"
              Background="{ThemeResource OkPanelOverVideoBrush}" BorderThickness="1,0,0,0" BorderBrush="{ThemeResource OkStrokeBrush}"
              RowDefinitions="Auto,*,Auto">
            <Grid.RenderTransform><TranslateTransform x:Name="PanelTransform" X="316" /></Grid.RenderTransform>

            <Grid Grid.Row="0" Padding="16,14,10,10" ColumnDefinitions="*,Auto">
                <TextBlock Text="Chapters" Style="{StaticResource OkTitleTextStyle}" VerticalAlignment="Center" />
                <Button Grid.Column="1" Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE711;"
                        Foreground="{ThemeResource OkTextSecondaryBrush}" Click="OnChaptersClick" ToolTipService.ToolTip="Close" />
            </Grid>

            <ListView x:Name="ChapterList" Grid.Row="1" SelectionMode="Single" Padding="6,0"
                      ItemsSource="{x:Bind Vm.Chapters, Mode=OneWay}" SelectionChanged="OnChapterSelectionChanged">
                <ListView.Resources>
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#1F10938A" />
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#2910938A" />
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#2910938A" />
                </ListView.Resources>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChapterInfo">
                        <Grid Padding="2,6" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Border Grid.Column="0" Width="56" Height="32" CornerRadius="4" Background="{ThemeResource OkSubtleFillStrongBrush}">
                                <Image Source="{x:Bind Thumbnail, Mode=OneWay}" Stretch="UniformToFill" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="{x:Bind Title}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" Style="{StaticResource OkBodyTextStyle}" />
                            <TextBlock Grid.Column="2" Text="{x:Bind TimeText}" VerticalAlignment="Center" Style="{StaticResource OkSmallTextStyle}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border Grid.Row="2" Padding="14,10" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource OkStrokeBrush}">
                <TextBlock x:Name="ChaptersEmpty" Text="No chapters in this file." HorizontalAlignment="Center"
                           Style="{StaticResource OkSmallTextStyle}" />
            </Border>
        </Grid>

        <!-- ===== OSD toast (top-center, shared scrim style) ===== -->
        <Border x:Name="ToastHost" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,64,0,0" Padding="14,8" CornerRadius="12" Opacity="0" IsHitTestVisible="False"
                Background="{StaticResource OkOverVideoToastBrush}"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource OkOverVideoHairlineBrush}">
            <Border.RenderTransform><TranslateTransform x:Name="ToastTransform" Y="-8" /></Border.RenderTransform>
            <TextBlock x:Name="ToastText" Foreground="#F2FFFFFF" FontSize="13" FontWeight="Medium" />
        </Border>
    </Grid>
</UserControl>
