<?xml version="1.0" encoding="utf-8"?>
<!-- Type ramp. Segoe UI Variable (native Win11). CharacterSpacing is in 1/1000 em.
     Tabular-figure timecodes: WinUI TextBlock has no OpenType-feature API, so the timecode style
     uses the standard family for now (tabular fidelity is a later refinement). -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="OkFontFamily">Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="OkTextFontFamily">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="OkMonoFontFamily">Cascadia Code, Consolas</FontFamily>

    <!-- Display 30 / SemiBold / -0.5px -->
    <Style x:Key="OkDisplayTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OkFontFamily}" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="-17" />
        <Setter Property="Foreground" Value="{ThemeResource OkTextPrimaryBrush}" />
    </Style>

    <!-- Page / app title 26 / SemiBold / -0.4px -->
    <Style x:Key="OkPageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OkFontFamily}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="-15" />
        <Setter Property="Foreground" Value="{ThemeResource OkTextPrimaryBrush}" />
    </Style>

    <!-- Settings page title 22 / SemiBold -->
    <Style x:Key="OkSettingsTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OkFontFamily}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="-14" />
        <Setter Property="Foreground" Value="{ThemeResource OkTextPrimaryBrush}" />
    </Style>

    <!-- Panel header 18 / SemiBold -->
    <Style x:Key="OkPanelHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OkTextFontFamily}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource OkTextPrimaryBrush}" />
    </Style>

    <!-- Section / card title 16 / SemiBold -->
    <Style x:Key="OkTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OkTextFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource OkTextPrimaryBrush}" />
    </Style>

    <!-- Body 14 / Regular -->
    <Style x:Key="OkBodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OkTextFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource OkTextBodyBrush}" />
    </Style>

    <!-- Body emphasis 13 / SemiBold -->
    <Style x:Key="OkBodyStrongTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OkTextFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource OkTextPrimaryBrush}" />
    </Style>

    <!-- Small / metadata 12 / Regular -->
    <Style x:Key="OkSmallTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OkTextFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource OkTextSecondaryBrush}" />
    </Style>

    <!-- Caption 11 / Medium -->
    <Style x:Key="OkCaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OkTextFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{ThemeResource OkTextTertiaryBrush}" />
    </Style>

    <!-- Eyebrow (UPPERCASE in markup) 11 / SemiBold / +0.06em -->
    <Style x:Key="OkEyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OkTextFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Foreground" Value="{ThemeResource OkTextTertiaryBrush}" />
    </Style>

    <!-- Timecode 12 / Medium (tabular fidelity TODO) -->
    <Style x:Key="OkTimecodeTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OkTextFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{ThemeResource OkTextSecondaryBrush}" />
    </Style>

</ResourceDictionary>
