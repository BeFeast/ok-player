<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OkPlayer.App.Controls.SeekBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="18"
    HorizontalContentAlignment="Stretch">

    <Grid x:Name="Root" Background="Transparent"
          PointerPressed="OnPointerPressed"
          PointerMoved="OnPointerMoved"
          PointerReleased="OnPointerReleased"
          PointerCanceled="OnPointerCanceled"
          PointerCaptureLost="OnPointerCaptureLost"
          PointerExited="OnPointerExited">

        <!-- track -->
        <Border Height="5" CornerRadius="3" VerticalAlignment="Center"
                Background="{StaticResource OkSeekTrackBrush}" />
        <!-- buffered band (behind the fill) -->
        <Border x:Name="BufferedBar" Height="5" CornerRadius="3" Width="0"
                VerticalAlignment="Center" HorizontalAlignment="Left" Background="#61FFFFFF" />
        <!-- played fill -->
        <Border x:Name="FillBar" Height="5" CornerRadius="3" Width="0"
                VerticalAlignment="Center" HorizontalAlignment="Left"
                Background="{StaticResource OkSeekFillBrush}" />
        <!-- A–B loop region (tinted band between the two points) -->
        <Border x:Name="AbBand" Height="9" CornerRadius="3" Width="0" Visibility="Collapsed"
                VerticalAlignment="Center" HorizontalAlignment="Left" Background="#8044E0D3" IsHitTestVisible="False" />
        <!-- chapter ticks -->
        <Canvas x:Name="TickCanvas" Height="9" VerticalAlignment="Center" IsHitTestVisible="False" />
        <!-- A–B loop point markers -->
        <Border x:Name="AbMarkerA" Width="2" Height="13" CornerRadius="1" Visibility="Collapsed"
                VerticalAlignment="Center" HorizontalAlignment="Left" Background="{ThemeResource OkSeekFillBrush}" IsHitTestVisible="False" />
        <Border x:Name="AbMarkerB" Width="2" Height="13" CornerRadius="1" Visibility="Collapsed"
                VerticalAlignment="Center" HorizontalAlignment="Left" Background="{ThemeResource OkSeekFillBrush}" IsHitTestVisible="False" />
        <!-- thumb -->
        <Ellipse x:Name="ThumbDot" Width="13" Height="13" Fill="White"
                 VerticalAlignment="Center" HorizontalAlignment="Left" />
    </Grid>
</UserControl>
