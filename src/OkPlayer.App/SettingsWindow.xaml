<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OkPlayer.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <media:MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <!-- Root: no opaque Background, so the MicaBackdrop shows through the inter-card base (the rail and every
         card paint their own surfaces). MicaBackdrop supplies its own solid fallback when transparency is off. -->
    <Grid>

        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.ThemeDictionaries>
                    <!-- Window-scoped rail tints, matched to the design's barely-there rail surface
                         (rgba(0,0,0,.015) / rgba(255,255,255,.02)) and .72/.74 label colour. Kept local so no
                         global brush is added. -->
                    <ResourceDictionary x:Key="Light">
                        <SolidColorBrush x:Key="OkRailFillBrush" Color="#04000000" />
                        <SolidColorBrush x:Key="OkRailTextBrush" Color="#B8000000" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="Dark">
                        <SolidColorBrush x:Key="OkRailFillBrush" Color="#05FFFFFF" />
                        <SolidColorBrush x:Key="OkRailTextBrush" Color="#BDFFFFFF" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="HighContrast">
                        <SolidColorBrush x:Key="OkRailFillBrush" Color="{ThemeResource SystemColorWindowColor}" />
                        <SolidColorBrush x:Key="OkRailTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>

                <!-- Shared rail-item container style for BOTH the main nav list and the About footer list.
                     Replaces the stock WinUI selection visual with the design's treatment: an accent-soft
                     fill, a full-height 3px accent left bar, and accent SemiBold label/icon — all driven off
                     the Ok* accent brushes (theme + System/teal accent aware), never the OS accent. -->
                <Style x:Key="OkRailItemStyle" TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{ThemeResource OkRailTextBrush}" />
                    <Setter Property="Padding" Value="10,8" />
                    <Setter Property="Margin" Value="0,0,0,2" />
                    <Setter Property="MinHeight" Value="34" />
                    <Setter Property="CornerRadius" Value="7" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="UseSystemFocusVisuals" Value="True" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Grid Background="Transparent" CornerRadius="{TemplateBinding CornerRadius}">
                                    <Border x:Name="SelectionFill" CornerRadius="{TemplateBinding CornerRadius}"
                                            Background="{ThemeResource OkAccentSelectionFillBrush}" Opacity="0" />
                                    <Rectangle x:Name="AccentBar" Width="3" RadiusX="1.5" RadiusY="1.5"
                                               HorizontalAlignment="Left" Fill="{ThemeResource OkAccentRailBrush}" Opacity="0" />
                                    <ContentPresenter x:Name="ContentPresenter"
                                                      Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      Padding="{TemplateBinding Padding}"
                                                      Foreground="{TemplateBinding Foreground}"
                                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal" />
                                            <VisualState x:Name="PointerOver">
                                                <VisualState.Setters>
                                                    <Setter Target="SelectionFill.Background" Value="{ThemeResource OkSubtleFillBrush}" />
                                                    <Setter Target="SelectionFill.Opacity" Value="1" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Pressed">
                                                <VisualState.Setters>
                                                    <Setter Target="SelectionFill.Background" Value="{ThemeResource OkSubtleFillStrongBrush}" />
                                                    <Setter Target="SelectionFill.Opacity" Value="1" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Target="SelectionFill.Opacity" Value="1" />
                                                    <Setter Target="AccentBar.Opacity" Value="1" />
                                                    <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource OkAccentTextBrush}" />
                                                    <Setter Target="ContentPresenter.FontWeight" Value="SemiBold" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="PointerOverSelected">
                                                <VisualState.Setters>
                                                    <Setter Target="SelectionFill.Background" Value="{ThemeResource OkAccentTintBrush}" />
                                                    <Setter Target="SelectionFill.Opacity" Value="1" />
                                                    <Setter Target="AccentBar.Opacity" Value="1" />
                                                    <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource OkAccentTextBrush}" />
                                                    <Setter Target="ContentPresenter.FontWeight" Value="SemiBold" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="PressedSelected">
                                                <VisualState.Setters>
                                                    <Setter Target="SelectionFill.Background" Value="{ThemeResource OkAccentTintBrush}" />
                                                    <Setter Target="SelectionFill.Opacity" Value="1" />
                                                    <Setter Target="AccentBar.Opacity" Value="1" />
                                                    <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource OkAccentTextBrush}" />
                                                    <Setter Target="ContentPresenter.FontWeight" Value="SemiBold" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ResourceDictionary>
        </Grid.Resources>

        <!-- body: 192px nav rail + content pane. It fills the whole window so the nav rail runs full
             height to the top edge; the caption strip below is a transparent overlay, so there's no
             separate full-width title band cutting the rail off. -->
        <Grid ColumnDefinitions="192,*">

            <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="{ThemeResource OkCardStrokeBrush}" Background="{ThemeResource OkRailFillBrush}">
                <Grid Padding="10,54,10,12" RowDefinitions="*,Auto,Auto">
                <StackPanel Grid.Row="0">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1"
                            BorderBrush="{ThemeResource OkStrokeBrush}" CornerRadius="7" Padding="10,7" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE721;" FontSize="13" Foreground="{ThemeResource OkTextTertiaryBrush}" />
                            <TextBlock Text="Search" FontSize="12" Foreground="{ThemeResource OkTextTertiaryBrush}" />
                        </StackPanel>
                    </Border>

                    <ListView x:Name="NavList" SelectionMode="Single" SelectedIndex="-1" SelectionChanged="OnNavChanged"
                              Padding="0" ItemContainerStyle="{StaticResource OkRailItemStyle}">
                        <ListViewItem>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE706;" FontSize="16" /><TextBlock Text="Appearance" VerticalAlignment="Center" FontSize="12.5" />
                            </StackPanel>
                        </ListViewItem>
                        <ListViewItem>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE768;" FontSize="16" /><TextBlock Text="Playback" VerticalAlignment="Center" FontSize="12.5" />
                            </StackPanel>
                        </ListViewItem>
                        <ListViewItem>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xED1E;" FontSize="16" /><TextBlock Text="Subtitles" VerticalAlignment="Center" FontSize="12.5" />
                            </StackPanel>
                        </ListViewItem>
                        <ListViewItem>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE7F4;" FontSize="16" /><TextBlock Text="Video" VerticalAlignment="Center" FontSize="12.5" />
                            </StackPanel>
                        </ListViewItem>
                        <ListViewItem>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE767;" FontSize="16" /><TextBlock Text="Audio" VerticalAlignment="Center" FontSize="12.5" />
                            </StackPanel>
                        </ListViewItem>
                        <ListViewItem>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE765;" FontSize="16" /><TextBlock Text="Shortcuts" VerticalAlignment="Center" FontSize="12.5" />
                            </StackPanel>
                        </ListViewItem>
                        <ListViewItem>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE71B;" FontSize="16" /><TextBlock Text="Integration" VerticalAlignment="Center" FontSize="12.5" />
                            </StackPanel>
                        </ListViewItem>
                        <ListViewItem>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE943;" FontSize="16" /><TextBlock Text="Advanced" VerticalAlignment="Center" FontSize="12.5" />
                            </StackPanel>
                        </ListViewItem>
                    </ListView>
                </StackPanel>

                <!-- About is pinned to the bottom of the rail under a flexible spacer (the * row above) and a
                     hairline divider, per the design. It lives in its own one-item list so the selection
                     coordinates with the main list (OnNavChanged clears the other when one is picked). -->
                <Border Grid.Row="1" Height="1" Background="{ThemeResource OkCardStrokeBrush}" Margin="9,6,9,8" />
                <ListView x:Name="NavFooterList" Grid.Row="2" SelectionMode="Single" SelectedIndex="-1"
                          SelectionChanged="OnNavChanged" Padding="0" ItemContainerStyle="{StaticResource OkRailItemStyle}">
                    <ListViewItem>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE946;" FontSize="16" /><TextBlock Text="About" VerticalAlignment="Center" FontSize="12.5" />
                        </StackPanel>
                    </ListViewItem>
                </ListView>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1" Padding="24,70,44,28" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <!-- Appearance (real) -->
                    <StackPanel x:Name="AppearancePanel">
                        <TextBlock Text="Appearance" Style="{StaticResource OkSettingsTitleTextStyle}" />

                        <!-- THEME -->
                        <TextBlock Text="THEME" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,22,0,10" />
                        <Border Background="{ThemeResource ControlFillColorTertiaryBrush}" CornerRadius="8" Padding="3"
                                Width="240" HorizontalAlignment="Left">
                            <Grid ColumnDefinitions="*,*,*">
                                <Button x:Name="ThemeLightBtn" Grid.Column="0" Content="Light" Click="OnThemeLight"
                                        HorizontalAlignment="Stretch" CornerRadius="6" Padding="0,5" FontSize="12.5"
                                        Background="Transparent" BorderThickness="0" />
                                <Button x:Name="ThemeDarkBtn" Grid.Column="1" Content="Dark" Click="OnThemeDark"
                                        HorizontalAlignment="Stretch" CornerRadius="6" Padding="0,5" FontSize="12.5"
                                        Background="Transparent" BorderThickness="0" />
                                <Button x:Name="ThemeAutoBtn" Grid.Column="2" Content="Auto" Click="OnThemeAuto"
                                        HorizontalAlignment="Stretch" CornerRadius="6" Padding="0,5" FontSize="12.5"
                                        Background="Transparent" BorderThickness="0" />
                            </Grid>
                        </Border>
                        <TextBlock Text="Auto follows the system &#x2014; dark renders most evenings." FontSize="11.5"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,8,0,0" />

                        <!-- ACCENT -->
                        <TextBlock Text="ACCENT" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,24,0,12" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="AccentSystemBtn" Click="OnAccentSystem" CornerRadius="8" Padding="10,12"
                                    Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource OkStrokeBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <Border x:Name="SystemAccentSwatch" Width="18" Height="18" CornerRadius="5" />
                                    <TextBlock Text="System accent" FontSize="12.5" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="AccentTealBtn" Click="OnAccentTeal" CornerRadius="8" Padding="10,12"
                                    Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource OkStrokeBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <Border Width="18" Height="18" CornerRadius="5" Background="#FF10938A" />
                                    <TextBlock Text="OK Player teal" FontSize="12.5" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Playback (real) -->
                    <StackPanel x:Name="PlaybackPanel" Visibility="Collapsed">
                        <TextBlock Text="Playback" Style="{StaticResource OkSettingsTitleTextStyle}" />

                        <TextBlock Text="RESUME" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,22,0,8" />
                        <ToggleSwitch x:Name="ResumeToggle" OnContent="Resume where you left off"
                                      OffContent="Always start from the beginning" Toggled="OnResumeToggled" />
                        <TextBlock Text="Reopens a file at the position you stopped (skips the first 5% and the last 30s)."
                                   FontSize="11.5" Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,4,0,0" />

                        <TextBlock Text="ON-SCREEN CONTROLS" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,22,0,8" />
                        <ToggleSwitch x:Name="HidePausedToggle" OnContent="Hide controls when paused"
                                      OffContent="Keep controls visible when paused" Toggled="OnHidePausedToggled" />
                        <TextBlock Text="Auto-hides the controls 2.5s after you pause, the same as during playback. Move the mouse to show them again."
                                   FontSize="11.5" Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,4,0,0" />

                        <TextBlock Text="DEFAULT SPEED" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,24,0,10" />
                        <Border Background="{ThemeResource ControlFillColorTertiaryBrush}" CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="Speed075" Tag="0.75" Content="0.75&#x00D7;" Click="OnSpeedDefault" Width="58" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="Speed100" Tag="1.0"  Content="1&#x00D7;"    Click="OnSpeedDefault" Width="52" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="Speed125" Tag="1.25" Content="1.25&#x00D7;" Click="OnSpeedDefault" Width="58" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="Speed150" Tag="1.5"  Content="1.5&#x00D7;"  Click="OnSpeedDefault" Width="54" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="Speed200" Tag="2.0"  Content="2&#x00D7;"    Click="OnSpeedDefault" Width="52" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="ARROW-KEY SKIP" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,24,0,10" />
                        <Border Background="{ThemeResource ControlFillColorTertiaryBrush}" CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="Skip5"  Tag="5"  Content="5s"  Click="OnSkipStep" Width="52" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="Skip10" Tag="10" Content="10s" Click="OnSkipStep" Width="52" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="Skip30" Tag="30" Content="30s" Click="OnSkipStep" Width="52" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="The Left / Right arrows seek by this amount (J / L always jump 10s)." FontSize="11.5"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- Subtitles (real) -->
                    <StackPanel x:Name="SubtitlesPanel" Visibility="Collapsed">
                        <TextBlock Text="Subtitles" Style="{StaticResource OkSettingsTitleTextStyle}" />
                        <TextBlock Text="SIZE" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,22,0,10" />
                        <Border Background="{ThemeResource ControlFillColorTertiaryBrush}" CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="SubSmall"  Tag="0.8" Content="Small"  Click="OnSubSize" Width="74" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="SubNormal" Tag="1.0" Content="Normal" Click="OnSubSize" Width="74" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="SubLarge"  Tag="1.4" Content="Large"  Click="OnSubSize" Width="74" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="POSITION" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,24,0,10" />
                        <Border Background="{ThemeResource ControlFillColorTertiaryBrush}" CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="SubBottom" Tag="100" Content="Standard" Click="OnSubPos" Width="84" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="SubRaised" Tag="90"  Content="Raised"   Click="OnSubPos" Width="84" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="STYLE" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,24,0,10" />
                        <Border Background="{ThemeResource ControlFillColorTertiaryBrush}" CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="SubStyleDefault"  Tag="Default"  Content="Default"       Click="OnSubStyle" Width="96" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="SubStyleBold"     Tag="Bold"     Content="Bold"          Click="OnSubStyle" Width="96" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="SubStyleClassic"  Tag="Classic"  Content="Classic"       Click="OnSubStyle" Width="96" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="SubStyleContrast" Tag="Contrast" Content="High contrast" Click="OnSubStyle" Width="110" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Style affects text subtitles (SRT); ASS/SSA tracks keep their own built-in styling."
                                   TextWrapping="Wrap" MaxWidth="520" HorizontalAlignment="Left" FontSize="11.5"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,8,0,0" />
                        <TextBlock Text="Defaults for newly opened files. Tweak the current file (size, delay) from the subtitles button on the controls."
                                   TextWrapping="Wrap" MaxWidth="520" HorizontalAlignment="Left" FontSize="11.5"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- Video (real) -->
                    <StackPanel x:Name="VideoPanel" Visibility="Collapsed">
                        <TextBlock Text="Video" Style="{StaticResource OkSettingsTitleTextStyle}" />
                        <TextBlock Text="HARDWARE DECODING" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,22,0,10" />
                        <Border Background="{ThemeResource ControlFillColorTertiaryBrush}" CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="Hwdec1" Tag="1" Content="Auto" Click="OnHwdec" Width="74" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="Hwdec0" Tag="0" Content="Off"  Click="OnHwdec" Width="74" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Decode video on the GPU where it's safely supported (recommended). Turn off to force software decoding. Restart OK Player to apply."
                                   TextWrapping="Wrap" MaxWidth="520" HorizontalAlignment="Left" FontSize="11.5"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- Audio (real) -->
                    <StackPanel x:Name="AudioPanel" Visibility="Collapsed">
                        <TextBlock Text="Audio" Style="{StaticResource OkSettingsTitleTextStyle}" />
                        <TextBlock Text="DEFAULT VOLUME" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,22,0,10" />
                        <Border Background="{ThemeResource ControlFillColorTertiaryBrush}" CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="Vol50"  Tag="50"  Content="50%"  Click="OnDefaultVolume" Width="60" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="Vol75"  Tag="75"  Content="75%"  Click="OnDefaultVolume" Width="60" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                                <Button x:Name="Vol100" Tag="100" Content="100%" Click="OnDefaultVolume" Width="60" CornerRadius="6" Padding="0,5" FontSize="12.5" Background="Transparent" BorderThickness="0" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="The volume OK Player starts at when it launches." FontSize="11.5"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,8,0,0" />

                        <TextBlock Text="LOUDNESS" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,28,0,10" />
                        <ToggleSwitch x:Name="NormalizeToggle" OnContent="Even out loud and quiet parts"
                                      OffContent="Off" Toggled="OnNormalizeToggled" />
                        <TextBlock Text="Night mode: smooths the gap between quiet dialogue and loud effects so you don't keep reaching for the volume."
                                   TextWrapping="Wrap" MaxWidth="460" HorizontalAlignment="Left" FontSize="11.5"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- Shortcuts (real) — keyboard reference -->
                    <StackPanel x:Name="ShortcutsPanel" Visibility="Collapsed">
                        <TextBlock Text="Shortcuts" Style="{StaticResource OkSettingsTitleTextStyle}" />
                        <StackPanel x:Name="ShortcutsHost" Margin="0,16,0,0" />
                        <TextBlock Text="Custom rebinding is on the way. Today these keys are fixed; some also adjust with Settings &#x2192; Playback (skip step)."
                                   TextWrapping="Wrap" MaxWidth="460" HorizontalAlignment="Left" FontSize="11.5"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,18,0,0" />
                    </StackPanel>

                    <!-- Advanced (real) — the power-user escape hatch (PRD: raw mpv config) -->
                    <StackPanel x:Name="AdvancedPanel" Visibility="Collapsed">
                        <TextBlock Text="Advanced" Style="{StaticResource OkSettingsTitleTextStyle}" />

                        <TextBlock Text="MPV CONFIGURATION" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,22,0,10" />
                        <TextBlock TextWrapping="Wrap" MaxWidth="560" HorizontalAlignment="Left" FontSize="12.5"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}"
                                   Text="OK Player ships smart defaults. Power users can pass raw options straight to the mpv engine &#x2014; one key=value per row, like an mpv.conf. Engine-critical options (video output, the on-screen controls, the keyboard map) are protected and ignored here." />

                        <!-- The keys/values are mpv options (this file is read by libmpv) — link the manual's
                             options reference so power users can look up what is available without leaving. -->
                        <HyperlinkButton Content="Browse all mpv options &#x2197;" HorizontalAlignment="Left"
                                         NavigateUri="https://mpv.io/manual/stable/#options"
                                         FontSize="12.5" Padding="0,2" Margin="0,4,0,0"
                                         ToolTipService.ToolTip="Open the mpv manual (options reference) in your browser" />

                        <!-- editable key=value rows, each one mpv.conf line. A protected key shows an "ignored"
                             hint; the value uses the mpv.conf monospace feel. Backed by an ObservableCollection
                             (ItemsSource set in code-behind); rows persist across a theme restyle. -->
                        <ItemsControl x:Name="MpvOptionsList" Margin="0,14,0,0" MaxWidth="560" HorizontalAlignment="Left">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6" ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Loaded="OnRowKeyLoaded" PlaceholderText="option"
                                                 Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Cascadia Code, Consolas" FontSize="12.5" MinHeight="34"
                                                 IsSpellCheckEnabled="False" />
                                        <TextBlock Grid.Column="1" Text="=" VerticalAlignment="Center" FontSize="13"
                                                   Foreground="{ThemeResource OkTextSecondaryBrush}" />
                                        <TextBox Grid.Column="2" PlaceholderText="value"
                                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Cascadia Code, Consolas" FontSize="12.5" MinHeight="34"
                                                 IsSpellCheckEnabled="False" />
                                        <FontIcon Grid.Column="3" Glyph="&#xE946;" FontSize="15" Margin="2,0,0,0"
                                                  VerticalAlignment="Center" Foreground="{ThemeResource OkTextSecondaryBrush}"
                                                  Visibility="{Binding ProtectedVisibility, Mode=OneWay}"
                                                  ToolTipService.ToolTip="Ignored &#x2014; managed by OK Player" />
                                        <Button Grid.Column="4" Click="OnRemoveOption" Width="32" Height="32" Padding="0"
                                                CornerRadius="7" Background="Transparent" BorderThickness="0"
                                                Foreground="{ThemeResource OkTextSecondaryBrush}"
                                                ToolTipService.ToolTip="Remove option">
                                            <FontIcon Glyph="&#xE711;" FontSize="12" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Click="OnAddOption" Margin="0,4,0,0" CornerRadius="7" Padding="11,6"
                                Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource OkStrokeBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon Glyph="&#xE710;" FontSize="12" />
                                <TextBlock Text="Add option" FontSize="12.5" />
                            </StackPanel>
                        </Button>

                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0" VerticalAlignment="Center">
                            <Button x:Name="MpvConfSaveBtn" Content="Save" Click="OnMpvConfSave" CornerRadius="7" Padding="16,7"
                                    FontSize="12.5" FontWeight="SemiBold" Background="{ThemeResource OkAccentBrush}"
                                    Foreground="{ThemeResource OkOnAccentBrush}" BorderThickness="0" />
                            <Button Content="Open config folder" Click="OnOpenConfigFolder" CornerRadius="7" Padding="14,7"
                                    FontSize="12.5" Background="Transparent" BorderThickness="1" BorderBrush="{ThemeResource OkStrokeBrush}" />
                            <TextBlock x:Name="MpvConfStatus" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource OkAccentTextBrush}" />
                        </StackPanel>
                        <TextBlock Text="Restart OK Player to apply changes." FontSize="11.5"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,10,0,0" />
                    </StackPanel>

                    <!-- About — bespoke brand illustration + App/Engine/Host spec sheet + footer (its own nav tab,
                         below Advanced). Replaces the former brand-badge box. The triangle illustration is FIXED
                         brand teal (it is the logo); only incidental chrome (the channel/ON tags, footer links,
                         the stale-build tag) follows the live accent via the Ok* brushes. Spec values are a static
                         snapshot populated in code-behind (PopulateAbout); the libmpv line and the stale-build tag
                         fill in live. -->
                    <StackPanel x:Name="AboutPanel" Visibility="Collapsed">
                        <StackPanel.Resources>
                            <ResourceDictionary>
                                <!-- Theme-specific fixed colours with no shared-brush equivalent: the illustration's
                                     trailing ticks and the amber "behind main" build-state. Scoped to About so no
                                     new global brush is added; ThemeResource resolves them per Light/Dark/HC. -->
                                <ResourceDictionary.ThemeDictionaries>
                                    <ResourceDictionary x:Key="Light">
                                        <SolidColorBrush x:Key="AboutTickBrush" Color="#FF10938A" />
                                    </ResourceDictionary>
                                    <ResourceDictionary x:Key="Dark">
                                        <SolidColorBrush x:Key="AboutTickBrush" Color="#FF28B3AA" />
                                    </ResourceDictionary>
                                    <ResourceDictionary x:Key="HighContrast">
                                        <SolidColorBrush x:Key="AboutTickBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                                    </ResourceDictionary>
                                </ResourceDictionary.ThemeDictionaries>

                                <Style x:Key="AboutCardStyle" TargetType="Border">
                                    <Setter Property="Background" Value="{ThemeResource OkSurfaceCardBrush}" />
                                    <Setter Property="BorderBrush" Value="{ThemeResource OkCardStrokeBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="CornerRadius" Value="8" />
                                    <Setter Property="Padding" Value="16,14" />
                                </Style>
                                <Style x:Key="AboutGroupLabelStyle" TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="CharacterSpacing" Value="100" />
                                    <Setter Property="Foreground" Value="{ThemeResource OkTextTertiaryBrush}" />
                                    <Setter Property="Margin" Value="0,0,0,13" />
                                </Style>
                                <Style x:Key="AboutRowLabelStyle" TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                    <Setter Property="FontSize" Value="12.5" />
                                    <Setter Property="Foreground" Value="{ThemeResource OkTextSecondaryBrush}" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                                <Style x:Key="AboutValueStyle" TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Cascadia Code, Consolas" />
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="FontWeight" Value="Medium" />
                                    <Setter Property="Foreground" Value="{ThemeResource OkTextPrimaryBrush}" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="TextAlignment" Value="Right" />
                                </Style>
                                <Style x:Key="AboutValueWordStyle" TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                    <Setter Property="FontSize" Value="12.5" />
                                    <Setter Property="FontWeight" Value="Medium" />
                                    <Setter Property="Foreground" Value="{ThemeResource OkTextPrimaryBrush}" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="TextAlignment" Value="Right" />
                                </Style>
                                <Style x:Key="AboutTagBorderStyle" TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5" />
                                    <Setter Property="Padding" Value="6,2" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                                <Style x:Key="AboutTagTextStyle" TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                    <Setter Property="FontSize" Value="8.5" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="CharacterSpacing" Value="70" />
                                </Style>
                            </ResourceDictionary>
                        </StackPanel.Resources>

                        <!-- 1 · Identity hero -->
                        <Grid ColumnDefinitions="Auto,*">
                            <!-- Bespoke illustration: a gradient play-triangle resolving from a sweep of frame-ticks.
                                 Recreated from the design SVG (viewBox 124x96, shown 116x90) as native shapes; FIXED
                                 brand teal in both themes (only the faint trailing ticks shade per theme). -->
                            <Grid Grid.Column="0" Width="118" Height="94" Margin="0,0,22,0" VerticalAlignment="Center">
                                <Viewbox Width="116" Height="90" Stretch="Uniform">
                                    <Canvas Width="124" Height="96">
                                        <Rectangle Canvas.Left="14"   Canvas.Top="43.5" Width="5.5" Height="9"  RadiusX="2.75" RadiusY="2.75" Fill="{ThemeResource AboutTickBrush}" Opacity="0.10" />
                                        <Rectangle Canvas.Left="22"   Canvas.Top="41"   Width="5.5" Height="14" RadiusX="2.75" RadiusY="2.75" Fill="{ThemeResource AboutTickBrush}" Opacity="0.18" />
                                        <Rectangle Canvas.Left="31"   Canvas.Top="38"   Width="5.5" Height="20" RadiusX="2.75" RadiusY="2.75" Fill="{ThemeResource AboutTickBrush}" Opacity="0.30" />
                                        <Rectangle Canvas.Left="40.5" Canvas.Top="34"   Width="5.5" Height="28" RadiusX="2.75" RadiusY="2.75" Fill="{ThemeResource AboutTickBrush}" Opacity="0.44" />
                                        <Rectangle Canvas.Left="51"   Canvas.Top="30"   Width="5.5" Height="36" RadiusX="2.75" RadiusY="2.75" Fill="{ThemeResource AboutTickBrush}" Opacity="0.62" />
                                        <!-- soft drop shadow: an offset translucent copy of the triangle silhouette -->
                                        <Path Data="M64 22 L108 48 L64 74 Z" Fill="#0A655F" Stroke="#0A655F" StrokeThickness="6"
                                              StrokeLineJoin="Round" Opacity="0.34">
                                            <Path.RenderTransform>
                                                <TranslateTransform Y="6" />
                                            </Path.RenderTransform>
                                        </Path>
                                        <Path Data="M64 22 L108 48 L64 74 Z" StrokeThickness="6" StrokeLineJoin="Round">
                                            <Path.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#1CAFA2" Offset="0" />
                                                    <GradientStop Color="#118A80" Offset="0.55" />
                                                    <GradientStop Color="#0A655F" Offset="1" />
                                                </LinearGradientBrush>
                                            </Path.Fill>
                                            <Path.Stroke>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#1CAFA2" Offset="0" />
                                                    <GradientStop Color="#118A80" Offset="0.55" />
                                                    <GradientStop Color="#0A655F" Offset="1" />
                                                </LinearGradientBrush>
                                            </Path.Stroke>
                                        </Path>
                                    </Canvas>
                                </Viewbox>
                            </Grid>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="30" LineHeight="30"
                                           CharacterSpacing="-20" Foreground="{ThemeResource OkTextPrimaryBrush}">
                                    <Run Text="OK" FontWeight="Bold" /><Run Text=" " /><Run Text="Player" FontWeight="Light" />
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
                                    <Border Background="{ThemeResource OkSubtleFillBrush}" CornerRadius="6" Padding="9,3" VerticalAlignment="Center">
                                        <TextBlock x:Name="AboutHeroVersionChip" FontFamily="Cascadia Code, Consolas" FontSize="11.5"
                                                   FontWeight="SemiBold" Foreground="{ThemeResource OkTextPrimaryBrush}" />
                                    </Border>
                                    <Border Background="{ThemeResource OkAccentTintBrush}" CornerRadius="6" Padding="9,4" VerticalAlignment="Center">
                                        <TextBlock x:Name="AboutHeroChannelChip" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                                   CharacterSpacing="50" Foreground="{ThemeResource OkAccentTextBrush}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="The most elegant media player on Windows." FontFamily="Segoe UI" FontSize="13"
                                           LineHeight="18.2" TextWrapping="Wrap" Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,11,0,0" />
                                <TextBlock Text="Open source &#x00B7; by Oleg Kossoy" FontFamily="Segoe UI" FontSize="11.5"
                                           Foreground="{ThemeResource OkTextTertiaryBrush}" Margin="0,3,0,0" />
                            </StackPanel>
                        </Grid>

                        <!-- divider below the hero -->
                        <Border Height="1" Background="{ThemeResource OkCardStrokeBrush}" Margin="0,22,0,22" />

                        <!-- 2 · Spec sheet -->
                        <StackPanel Spacing="12">

                            <!-- APP -->
                            <Border Style="{StaticResource AboutCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="APP" Style="{StaticResource AboutGroupLabelStyle}" />
                                    <StackPanel Spacing="10">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Version" Style="{StaticResource AboutRowLabelStyle}" />
                                            <TextBlock Grid.Column="1" x:Name="AboutAppVersion" Style="{StaticResource AboutValueStyle}" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Channel" Style="{StaticResource AboutRowLabelStyle}" />
                                            <TextBlock Grid.Column="1" x:Name="AboutAppChannel" Style="{StaticResource AboutValueWordStyle}" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Build" Style="{StaticResource AboutRowLabelStyle}" />
                                            <TextBlock Grid.Column="1" x:Name="AboutBuildSha" Style="{StaticResource AboutValueStyle}" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="License" Style="{StaticResource AboutRowLabelStyle}" />
                                            <TextBlock Grid.Column="1" Text="GPL-3.0-or-later" Style="{StaticResource AboutValueStyle}" />
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- UPDATES -->
                            <Border Style="{StaticResource AboutCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="UPDATES" Style="{StaticResource AboutGroupLabelStyle}" />
                                    <StackPanel Spacing="10">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Status" Style="{StaticResource AboutRowLabelStyle}" />
                                            <TextBlock Grid.Column="1" x:Name="AboutUpdateStatus" Text="&#x2014;"
                                                       Style="{StaticResource AboutValueWordStyle}" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel>
                                                <TextBlock Text="Check automatically" Style="{StaticResource AboutRowLabelStyle}" />
                                                <TextBlock Text="On launch" FontFamily="Segoe UI" FontSize="11"
                                                           Foreground="{ThemeResource OkTextTertiaryBrush}" Margin="0,1,0,0" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="AutoUpdateToggle" MinWidth="0"
                                                          OnContent="" OffContent="" VerticalAlignment="Center"
                                                          Toggled="OnAutoUpdateToggled" />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                            <Button x:Name="CheckUpdatesButton" Content="Check for updates" Click="OnCheckForUpdates"
                                                    CornerRadius="7" Padding="14,7" FontSize="12.5" />
                                            <Button x:Name="RestartNowButton" Content="Restart to update" Click="OnRestartNow"
                                                    CornerRadius="7" Padding="14,7" FontSize="12.5" Visibility="Collapsed"
                                                    Background="{ThemeResource OkAccentBrush}" Foreground="{ThemeResource OkOnAccentBrush}"
                                                    BorderThickness="0" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ENGINE -->
                            <Border Style="{StaticResource AboutCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="ENGINE" Style="{StaticResource AboutGroupLabelStyle}" />
                                    <StackPanel Spacing="10">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="libmpv" Style="{StaticResource AboutRowLabelStyle}" />
                                            <TextBlock Grid.Column="1" x:Name="AboutEngineMpv" Style="{StaticResource AboutValueStyle}" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="FFmpeg" Style="{StaticResource AboutRowLabelStyle}" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="&#x2014;" Style="{StaticResource AboutValueStyle}" />
                                                <Border Style="{StaticResource AboutTagBorderStyle}" Background="{ThemeResource OkSubtleFillBrush}">
                                                    <TextBlock Text="PLANNED" Style="{StaticResource AboutTagTextStyle}" Foreground="{ThemeResource OkTextTertiaryBrush}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Render API" Style="{StaticResource AboutRowLabelStyle}" />
                                            <TextBlock Grid.Column="1" Text="libmpv render" Style="{StaticResource AboutValueStyle}" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Graphics" Style="{StaticResource AboutRowLabelStyle}" />
                                            <TextBlock Grid.Column="1" x:Name="AboutEngineGraphics" Style="{StaticResource AboutValueStyle}" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Hardware decode" Style="{StaticResource AboutRowLabelStyle}" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock x:Name="AboutEngineHwdec" Style="{StaticResource AboutValueStyle}" />
                                                <Border x:Name="AboutHwdecTag" Style="{StaticResource AboutTagBorderStyle}"
                                                        Background="{ThemeResource OkAccentTintBrush}" Visibility="Collapsed">
                                                    <TextBlock Text="ON" Style="{StaticResource AboutTagTextStyle}" Foreground="{ThemeResource OkAccentTextBrush}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- HOST (two-column grid) -->
                            <Border Style="{StaticResource AboutCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="HOST" Style="{StaticResource AboutGroupLabelStyle}" />
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="26" RowSpacing="10">
                                        <Grid Grid.Row="0" Grid.Column="0" ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Windows 11" Style="{StaticResource AboutRowLabelStyle}" />
                                            <TextBlock Grid.Column="1" x:Name="AboutHostWindows" Style="{StaticResource AboutValueStyle}" />
                                        </Grid>
                                        <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto">
                                            <TextBlock Text=".NET" Style="{StaticResource AboutRowLabelStyle}" />
                                            <TextBlock Grid.Column="1" x:Name="AboutHostDotnet" Style="{StaticResource AboutValueStyle}" />
                                        </Grid>
                                        <Grid Grid.Row="1" Grid.Column="0" ColumnDefinitions="*,Auto">
                                            <TextBlock Text="App SDK" Style="{StaticResource AboutRowLabelStyle}" />
                                            <TextBlock Grid.Column="1" x:Name="AboutHostAppSdk" Style="{StaticResource AboutValueStyle}" />
                                        </Grid>
                                        <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto">
                                            <TextBlock Text="CPU" Style="{StaticResource AboutRowLabelStyle}" />
                                            <TextBlock Grid.Column="1" x:Name="AboutHostCpu" Style="{StaticResource AboutValueStyle}" />
                                        </Grid>
                                        <Grid Grid.Row="2" Grid.Column="0" ColumnDefinitions="*,Auto">
                                            <TextBlock Text="GPU" Style="{StaticResource AboutRowLabelStyle}" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="&#x2014;" Style="{StaticResource AboutValueStyle}" />
                                                <Border Style="{StaticResource AboutTagBorderStyle}" Background="{ThemeResource OkSubtleFillBrush}">
                                                    <TextBlock Text="PLANNED" Style="{StaticResource AboutTagTextStyle}" Foreground="{ThemeResource OkTextTertiaryBrush}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 3 · Footer -->
                        <Border Margin="0,8,0,0" Padding="0,17,0,0" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource OkCardStrokeBrush}">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Button Grid.Column="0" Click="OnCopyDiagnostics" CornerRadius="7" Padding="14,8"
                                        Background="{ThemeResource OkSubtleFillBrush}" BorderThickness="1" BorderBrush="{ThemeResource OkCardStrokeBrush}">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE8C8;" FontSize="14" Foreground="{ThemeResource OkTextPrimaryBrush}" />
                                        <TextBlock Text="Copy diagnostics" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource OkTextPrimaryBrush}" />
                                    </StackPanel>
                                </Button>
                                <TextBlock Grid.Column="1" x:Name="AboutCopyStatus" VerticalAlignment="Center" Margin="14,0,0,0"
                                           FontSize="12" Foreground="{ThemeResource OkAccentTextBrush}" />
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="13" VerticalAlignment="Center">
                                    <HyperlinkButton NavigateUri="https://github.com/BeFeast/ok-player" Padding="0"
                                                     Foreground="{ThemeResource OkAccentTextBrush}">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="GitHub" FontSize="12" FontWeight="SemiBold" />
                                            <TextBlock Text="&#x2197;" FontSize="12" />
                                        </StackPanel>
                                    </HyperlinkButton>
                                    <Ellipse Width="3" Height="3" Fill="{ThemeResource OkTextTertiaryBrush}" VerticalAlignment="Center" />
                                    <HyperlinkButton NavigateUri="https://github.com/BeFeast/ok-player/blob/main/LICENSE" Padding="0"
                                                     Foreground="{ThemeResource OkAccentTextBrush}">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="License" FontSize="12" FontWeight="SemiBold" />
                                            <TextBlock Text="&#x2197;" FontSize="12" />
                                        </StackPanel>
                                    </HyperlinkButton>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Integration (real) — file-type associations -->
                    <StackPanel x:Name="IntegrationPanel" Visibility="Collapsed">
                        <TextBlock Text="Integration" Style="{StaticResource OkSettingsTitleTextStyle}" />

                        <TextBlock Text="FILE ASSOCIATIONS" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,22,0,10" />
                        <TextBlock TextWrapping="Wrap" MaxWidth="560" HorizontalAlignment="Left" FontSize="12.5"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}"
                                   Text="Tick the file types OK Player should handle &#x2014; they then appear in Explorer's Open with and in Windows' Default apps. Windows decides which app is the default, so use the button below to set OK Player as the default for the types you ticked." />

                        <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,12,0,0">
                            <HyperlinkButton Content="Select all" Click="OnAssocSelectAll" Padding="6,2" FontSize="12.5" />
                            <HyperlinkButton Content="Clear all" Click="OnAssocClearAll" Padding="6,2" FontSize="12.5" />
                        </StackPanel>

                        <TextBlock Text="Video" FontSize="12.5" FontWeight="SemiBold" Margin="0,12,0,8" />
                        <VariableSizedWrapGrid x:Name="AssocVideoPanel" Orientation="Horizontal" ItemWidth="116" ItemHeight="34" />

                        <TextBlock Text="Audio" FontSize="12.5" FontWeight="SemiBold" Margin="0,16,0,8" />
                        <VariableSizedWrapGrid x:Name="AssocAudioPanel" Orientation="Horizontal" ItemWidth="116" ItemHeight="34" />

                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,20,0,0" VerticalAlignment="Center">
                            <Button Content="Set as default in Windows&#x2026;" Click="OnOpenDefaultApps" CornerRadius="7" Padding="14,7"
                                    FontSize="12.5" FontWeight="SemiBold" Background="{ThemeResource OkAccentBrush}"
                                    Foreground="{ThemeResource OkOnAccentBrush}" BorderThickness="0" />
                            <TextBlock x:Name="AssocStatus" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource OkAccentTextBrush}" />
                        </StackPanel>

                        <TextBlock Text="PRIVACY" FontSize="12" FontWeight="SemiBold" CharacterSpacing="60"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="0,30,0,10" />
                        <TextBlock TextWrapping="Wrap" MaxWidth="560" HorizontalAlignment="Left" FontSize="12.5"
                                   Foreground="{ThemeResource OkTextSecondaryBrush}"
                                   Text="OK Player remembers what you watched so it can resume and show Continue Watching. Use a private session (right-click menu) to watch without recording, set how long history is kept, or clear it now." />

                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,16,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Keep history for" VerticalAlignment="Center" FontSize="12.5" />
                            <ComboBox x:Name="RetentionCombo" SelectionChanged="OnRetentionChanged" MinWidth="150" FontSize="12.5">
                                <ComboBoxItem Content="Forever" />
                                <ComboBoxItem Content="7 days" />
                                <ComboBoxItem Content="30 days" />
                                <ComboBoxItem Content="90 days" />
                                <ComboBoxItem Content="1 year" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,16,0,0" VerticalAlignment="Center">
                            <Button Content="Clear watch history&#x2026;" Click="OnClearHistory" CornerRadius="7" Padding="14,7"
                                    FontSize="12.5" FontWeight="SemiBold" />
                            <TextBlock x:Name="HistoryStatus" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource OkAccentTextBrush}" />
                        </StackPanel>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- transparent drag strip over the very top: the OS caption buttons sit at the right, the title at
             the left. It overlays the full-height body, so the nav rail's background reaches the top edge. -->
        <Grid x:Name="AppTitleBar" Height="42" VerticalAlignment="Top" Background="Transparent" Padding="16,0,0,0">
            <TextBlock Text="Settings" VerticalAlignment="Center" FontSize="12.5" FontWeight="SemiBold"
                       Foreground="{ThemeResource OkTextSecondaryBrush}" />
        </Grid>
    </Grid>
</Window>
