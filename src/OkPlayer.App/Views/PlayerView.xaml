<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OkPlayer.App.Views.PlayerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:render="using:OkPlayer.Render"
    xmlns:ctl="using:OkPlayer.App.Controls">

    <UserControl.Resources>
        <Storyboard x:Name="ChromeShowSb">
            <DoubleAnimation Storyboard.TargetName="BottomChrome" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="BottomTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TitleChrome" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="TitleTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="ChromeHideSb">
            <DoubleAnimation Storyboard.TargetName="BottomChrome" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="BottomTransform" Storyboard.TargetProperty="Y" To="16" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TitleChrome" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="TitleTransform" Storyboard.TargetProperty="Y" To="-10" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="#FF050505" IsTabStop="True"
          PointerMoved="OnRootPointerMoved" KeyDown="OnRootKeyDown">

        <!-- the single video plane -->
        <render:MpvVideoPanel x:Name="Video" Tapped="OnVideoTapped" />

        <!-- ===== top chrome: scrim + title ===== -->
        <Grid x:Name="TitleChrome" VerticalAlignment="Top" Height="42" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="TitleTransform" Y="-10" /></Grid.RenderTransform>
            <Border Background="{StaticResource OkTopScrimBrush}" IsHitTestVisible="False" />
            <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center" Margin="14,0">
                <FontIcon Glyph="&#xE768;" FontSize="13" Foreground="#E6FFFFFF" />
                <TextBlock x:Name="TitleText" Text="{x:Bind Vm.MediaTitle, Mode=OneWay}"
                           Foreground="#F2FFFFFF" FontSize="12.5" FontWeight="Medium" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ===== bottom chrome: scrim + OSC pill ===== -->
        <Grid x:Name="BottomChrome" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="BottomTransform" Y="16" /></Grid.RenderTransform>

            <!-- bottom scrim -->
            <Border VerticalAlignment="Bottom" Height="220" IsHitTestVisible="False"
                    Background="{StaticResource OkBottomScrimBrush}" />

            <!-- OSC pill -->
            <Border VerticalAlignment="Bottom" Margin="16" Padding="14,9" CornerRadius="16"
                    Background="{StaticResource OkOverVideoFillBrush}" BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource OkOverVideoHairlineBrush}">
                <Border.Shadow><ThemeShadow /></Border.Shadow>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- left cluster -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Style="{StaticResource OkOscIconButtonStyle}" FontSize="22"
                                Content="{x:Bind Vm.PlayPauseGlyph, Mode=OneWay}" Click="OnPlayClick"
                                ToolTipService.ToolTip="Play / Pause (Space)" />
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE892;" FontSize="16"
                                Click="OnPrevClick" ToolTipService.ToolTip="Previous chapter" />
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE893;" FontSize="16"
                                Click="OnNextClick" ToolTipService.ToolTip="Next chapter" />
                        <TextBlock Text="{x:Bind Vm.CurrentTimeText, Mode=OneWay}" Margin="6,0,2,0"
                                   VerticalAlignment="Center" Foreground="#CCFFFFFF" FontSize="11.5" FontWeight="Medium" />
                    </StackPanel>

                    <!-- seekbar -->
                    <ctl:SeekBar x:Name="Seek" Grid.Column="1" VerticalAlignment="Center"
                                 Fraction="{x:Bind Vm.PositionFraction, Mode=OneWay}" />

                    <!-- right cluster -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind Vm.TrailingTimeText, Mode=OneWay}" Margin="2,0,8,0"
                                   VerticalAlignment="Center" Foreground="#CCFFFFFF" FontSize="11.5" FontWeight="Medium"
                                   Tapped="OnTrailingTimeTapped" />
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="{x:Bind Vm.VolumeGlyph, Mode=OneWay}"
                                Click="OnVolumeClick" ToolTipService.ToolTip="Mute (M)" />
                        <Button x:Name="SpeedChip" Style="{StaticResource OkSpeedChipStyle}" Margin="4,0"
                                Content="{x:Bind Vm.SpeedText, Mode=OneWay}" Click="OnSpeedClick"
                                ToolTipService.ToolTip="Playback speed" />
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE7F0;"
                                ToolTipService.ToolTip="Subtitles" />
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE8D6;"
                                ToolTipService.ToolTip="Audio" />
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE8FD;"
                                ToolTipService.ToolTip="Chapters (C)" />
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE722;"
                                Click="OnScreenshotClick" ToolTipService.ToolTip="Screenshot (S)" />
                        <Button x:Name="FullscreenButton" Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE740;"
                                Click="OnFullscreenClick" ToolTipService.ToolTip="Fullscreen (F)" />
                        <Button Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE712;"
                                ToolTipService.ToolTip="More" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
