<?xml version="1.0" encoding="utf-8"?>
<!-- Spacing (8px grid, 4px half-step), corner radii, motion durations, and fixed panel metrics. -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Spacing grid -->
    <x:Double x:Key="OkSpace4">4</x:Double>
    <x:Double x:Key="OkSpace8">8</x:Double>
    <x:Double x:Key="OkSpace12">12</x:Double>
    <x:Double x:Key="OkSpace16">16</x:Double>
    <x:Double x:Key="OkSpace24">24</x:Double>
    <x:Double x:Key="OkSpace32">32</x:Double>

    <Thickness x:Key="OkCardPadding">22</Thickness>
    <Thickness x:Key="OkPanelHeaderPadding">16,16,16,10</Thickness>

    <!-- Corner radii -->
    <CornerRadius x:Key="OkControlCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="OkRowCornerRadius">7</CornerRadius>
    <CornerRadius x:Key="OkChipCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="OkCardCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="OkPopoverCornerRadius">10</CornerRadius>
    <CornerRadius x:Key="OkOscCornerRadius">16</CornerRadius>

    <!-- Motion (durations; easing applied per-animation, ref cubic-bezier(0.25,0.1,0.25,1)) -->
    <Duration x:Key="OkMotionHover">0:0:0.1</Duration>
    <Duration x:Key="OkMotionChrome">0:0:0.18</Duration>
    <Duration x:Key="OkMotionPanel">0:0:0.25</Duration>

    <!-- Fixed surface metrics from the canvas -->
    <x:Double x:Key="OkRightPanelWidth">312</x:Double>
    <x:Double x:Key="OkSettingsRailWidth">192</x:Double>
    <x:Double x:Key="OkTitleBarHeight">42</x:Double>
    <x:Double x:Key="OkPopoverWidth">288</x:Double>

</ResourceDictionary>
