<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OkPlayer.App.Views.PlayerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:render="using:OkPlayer.Render"
    xmlns:ctl="using:OkPlayer.App.Controls"
    xmlns:vm="using:OkPlayer.App.ViewModels"
    xmlns:views="using:OkPlayer.App.Views"
    IsTabStop="True">

    <UserControl.Resources>
        <Storyboard x:Name="ChromeShowSb">
            <DoubleAnimation Storyboard.TargetName="BottomChrome" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="BottomTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TitleChrome" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="TitleTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="ChromeHideSb">
            <DoubleAnimation Storyboard.TargetName="BottomChrome" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="BottomTransform" Storyboard.TargetProperty="Y" To="16" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TitleChrome" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="TitleTransform" Storyboard.TargetProperty="Y" To="-10" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="ToastShowSb">
            <DoubleAnimation Storyboard.TargetName="ToastHost" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetName="ToastTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="ToastHideSb">
            <DoubleAnimation Storyboard.TargetName="ToastHost" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25" />
        </Storyboard>
        <Storyboard x:Name="PanelShowSb">
            <DoubleAnimation Storyboard.TargetName="ChaptersPanel" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" />
            <DoubleAnimation Storyboard.TargetName="PanelTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="PanelHideSb">
            <DoubleAnimation Storyboard.TargetName="ChaptersPanel" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
            <DoubleAnimation Storyboard.TargetName="PanelTransform" Storyboard.TargetProperty="X" To="316" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="Transparent" AllowDrop="True"
          KeyboardAcceleratorPlacementMode="Hidden"
          PointerMoved="OnRootPointerMoved" PointerPressed="OnRootPointerPressed"
          DragOver="OnDragOver" DragLeave="OnDragLeave" Drop="OnDrop">

        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="O" Invoked="OnOpenAccelerator" />
            <KeyboardAccelerator Modifiers="Control" Key="V" Invoked="OnPasteAccelerator" />
        </Grid.KeyboardAccelerators>

        <!-- right-click context menu (design band 11 — light material) -->
        <Grid.ContextFlyout>
            <MenuFlyout MenuFlyoutPresenterStyle="{StaticResource OkMenuFlyoutPresenterStyle}">
                <MenuFlyoutItem Text="Play / Pause" Click="OnPlayClick">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE768;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSubItem Text="Screenshot">
                    <MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE722;" /></MenuFlyoutSubItem.Icon>
                    <MenuFlyoutItem Text="Save frame" Click="OnScreenshotClick" />
                    <MenuFlyoutItem Text="Save frame with subtitles" Click="OnScreenshotWithSubsClick" />
                    <MenuFlyoutItem Text="Copy frame to clipboard" Click="OnCopyFrameClick" />
                </MenuFlyoutSubItem>
                <MenuFlyoutItem Text="A&#x2013;B loop" Click="OnAbLoopClick">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8EE;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Add bookmark here" Click="OnAddBookmarkClick">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE840;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Go to time&#x2026;" Click="OnGoToTimeClick">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE823;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Copy current time" Click="OnCopyTimeClick" IsEnabled="{x:Bind Vm.HasMedia, Mode=OneWay}">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Chapters" Click="OnChaptersClick">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8FD;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSubItem Text="Window">
                    <MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE740;" /></MenuFlyoutSubItem.Icon>
                    <MenuFlyoutItem Text="Fullscreen" Click="OnFullscreenClick" />
                    <MenuFlyoutItem Text="Mini player" Click="OnMiniPlayerClick" IsEnabled="{x:Bind Vm.HasMedia, Mode=OneWay}" />
                    <MenuFlyoutItem Text="Fit window to video" Click="OnFitToVideoClick" />
                    <ToggleMenuFlyoutItem x:Name="AlwaysOnTopToggle" Text="Always on top" Click="OnAlwaysOnTopClick" />
                </MenuFlyoutSubItem>
                <MenuFlyoutSubItem Text="Video" IsEnabled="{x:Bind Vm.HasMedia, Mode=OneWay}">
                    <MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE7F4;" /></MenuFlyoutSubItem.Icon>
                    <MenuFlyoutSubItem Text="Aspect ratio">
                        <MenuFlyoutItem Text="Auto" Tag="no" Click="OnAspectClick" />
                        <MenuFlyoutItem Text="16:9" Tag="16:9" Click="OnAspectClick" />
                        <MenuFlyoutItem Text="4:3" Tag="4:3" Click="OnAspectClick" />
                        <MenuFlyoutItem Text="2.35:1" Tag="2.35:1" Click="OnAspectClick" />
                    </MenuFlyoutSubItem>
                    <MenuFlyoutItem Text="Rotate 90&#x00B0;" Click="OnRotateClick" />
                    <MenuFlyoutItem Text="Fill screen (crop bars)" Click="OnFillScreenClick" />
                    <MenuFlyoutItem Text="Reset video" Click="OnResetVideoClick" />
                </MenuFlyoutSubItem>
                <MenuFlyoutItem Text="Open file&#x2026;" Click="OnOpenFromMenu">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8E5;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Open file location" Click="OnOpenFileLocationClick">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE838;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Close file" Click="OnCloseFileClick" IsEnabled="{x:Bind Vm.HasMedia, Mode=OneWay}">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE711;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <ToggleMenuFlyoutItem x:Name="PrivateModeToggle" Text="Private session" Click="OnPrivateModeClick">
                    <ToggleMenuFlyoutItem.Icon><FontIcon Glyph="&#xE72E;" /></ToggleMenuFlyoutItem.Icon>
                </ToggleMenuFlyoutItem>
                <MenuFlyoutItem Text="Media info&#x2026;" Click="OnMediaInfoClick" />
                <MenuFlyoutItem Text="Settings&#x2026;" Click="OnSettingsClick">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE713;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
        </Grid.ContextFlyout>

        <!-- black backdrop behind the video so a 1px swap-chain gap (e.g. the window's top edge in fullscreen)
             never shows the light Mica through it; only present once media is loaded -->
        <Border x:Name="VideoBackdrop" Background="#FF000000" Visibility="Collapsed" />
        <!-- the single video plane: only over Mica once media is loaded (Mica shows the light shell otherwise) -->
        <render:MpvVideoPanel x:Name="Video" Tapped="OnVideoTapped" DoubleTapped="OnVideoDoubleTapped" Visibility="Collapsed" />

        <!-- light-first empty / welcome state (over Mica) — hero + continue-watching shelf (PRD 2.2).
             Scrollable + min-height-locked to the viewport: the hero centres when short, scrolls (never
             clips the title) when the recents shelf makes it tall. -->
        <!-- light-first empty / welcome state (over Mica). Two layouts (design 2.2): a recents-forward
             "Continue watching" view when there are recents, and a centred first-run hero when there aren't. -->
        <Grid x:Name="WelcomeCard">

            <!-- FIRST RUN / no recents: centred hero. Scrollable + min-height-locked to the viewport so the
                 hero centres when the window is tall and scrolls (never clips) when it is short. -->
            <ScrollViewer x:Name="WelcomeFirstRun" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled" ZoomMode="Disabled">
                <Grid MinHeight="{Binding ViewportHeight, ElementName=WelcomeFirstRun}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="13" Padding="24">
                    <Border Width="52" Height="52" CornerRadius="14" HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                                <GradientStop Color="#15A89D" Offset="0" />
                                <GradientStop Color="#0A655F" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Viewbox Margin="11,15">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="OK" FontFamily="Segoe UI" FontSize="36" FontWeight="Bold" Foreground="White" LineHeight="36" />
                                <Path Fill="White" Stretch="Fill" Width="15" Height="22" Margin="3,1,0,0"
                                      VerticalAlignment="Center" Data="M0,0 L0,22 L15,11 Z" />
                            </StackPanel>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Welcome to OK Player" FontSize="17" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center" />
                    <Grid Width="280" HorizontalAlignment="Center" Background="Transparent" Tapped="OnWelcomeOpenTapped">
                        <Rectangle RadiusX="10" RadiusY="10" StrokeThickness="1.5" StrokeDashArray="4,3"
                                   Stroke="{ThemeResource TextFillColorTertiaryBrush}" Fill="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                        <StackPanel Padding="16" Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Open file&#x2026;" Foreground="{ThemeResource OkAccentTextBrush}" FontSize="12.5"
                                       FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="or drop a file, folder, or link" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="11" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- VARIATION A / has recents: recents-forward, left-aligned, footer pinned bottom -->
            <Grid x:Name="WelcomeVariationA" Visibility="Collapsed" RowDefinitions="*,Auto">
                <ScrollViewer x:Name="VariationAScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollMode="Disabled" ZoomMode="Disabled"
                              SizeChanged="OnRecentsViewportSizeChanged">
                    <Grid MinHeight="{Binding ViewportHeight, ElementName=VariationAScroll}">
                    <StackPanel MaxWidth="920" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="44,36">
                        <TextBlock Text="Continue watching" FontSize="30" FontWeight="SemiBold" CharacterSpacing="-15"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Pick up where you left off &#x2014; or open something new." FontSize="13.5" Margin="0,6,0,0"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <!-- recents row: show as many cards as fit the available width (no horizontal scroll —
                             the design's elegance bar). Older resumable files stay reachable via History. The
                             visible count is recomputed from the viewport width in OnRecentsViewportSizeChanged
                             (not this row's own width, which is content-sized and can't grow back once shrunk). -->
                        <Grid x:Name="RecentsRow" Margin="0,22,0,0">
                            <ItemsControl ItemsSource="{x:Bind VisibleRecents}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="14" /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RecentEntry">
                                        <Button Click="OnRecentClick" Tag="{x:Bind Path}" Width="194" Padding="0"
                                                Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                                            <StackPanel Spacing="7">
                                                <Border Height="110" CornerRadius="8">
                                                    <Grid>
                                                        <Border Background="{x:Bind PlaceholderGradient}" />
                                                        <Image Source="{x:Bind Poster, Mode=OneWay}" Stretch="UniformToFill" />
                                                        <Grid VerticalAlignment="Bottom" Height="4" Background="#4DFFFFFF">
                                                            <Border HorizontalAlignment="Left" Background="{ThemeResource OkSeekFillBrush}" Width="{x:Bind ProgressFillWidth}" />
                                                        </Grid>
                                                        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,7,9"
                                                                CornerRadius="5" Padding="6,2" Background="#80000000">
                                                            <TextBlock Text="{x:Bind TimeLeft}" FontSize="10" FontWeight="SemiBold" Foreground="White" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="{x:Bind Title}" FontSize="13" FontWeight="Medium" MaxLines="1"
                                                           TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                                <TextBlock Text="{x:Bind Meta}" FontSize="11.5" Margin="0,-3,0,0"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                        <!-- recents that don't fit the row, opened in a flyout so every resumable file stays
                             reachable without a horizontal scrollbar (a full History view is separate work) -->
                        <Button x:Name="MoreRecentsLink" Visibility="Collapsed" Margin="2,7,0,0" Padding="4,2"
                                Background="Transparent" BorderThickness="0">
                            <TextBlock x:Name="MoreRecentsText" FontSize="12" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <Button.Flyout>
                                <Flyout Placement="Top">
                                    <StackPanel Width="300">
                                        <TextBlock Text="MORE TO CONTINUE" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="6,2,6,6" />
                                        <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{x:Bind OverflowRecents}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:RecentEntry">
                                                        <Button Click="OnRecentClick" Tag="{x:Bind Path}" Style="{StaticResource OkSwitcherRowStyle}"
                                                                HorizontalContentAlignment="Stretch">
                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                                <TextBlock Grid.Column="0" Text="{x:Bind Title}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="1" Text="{x:Bind TimeLeft}" FontSize="11"
                                                                           Foreground="{ThemeResource OkTextSecondaryBrush}" VerticalAlignment="Center" />
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!-- actions + drop zone -->
                        <Grid Margin="0,26,0,0" ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <StackPanel Grid.Column="0" Spacing="9" VerticalAlignment="Center">
                                <Button Click="OnWelcomeOpenClick" Background="{ThemeResource OkAccentBrush}" Foreground="White"
                                        CornerRadius="7" Padding="20,11" BorderThickness="0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8B7;" FontSize="15" Foreground="White" />
                                        <TextBlock Text="Open file&#x2026;" FontSize="13" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                                <Button Click="OnOpenUrlClick" Background="{ThemeResource OkSubtleFillStrongBrush}"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="7" Padding="18,10"
                                        BorderThickness="1" BorderBrush="{ThemeResource OkStrokeBrush}" HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE71B;" FontSize="14" />
                                        <TextBlock Text="Open URL&#x2026;" FontSize="12.5" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <Grid Grid.Column="1" Background="Transparent" Tapped="OnWelcomeOpenTapped" MinHeight="92">
                                <Rectangle RadiusX="9" RadiusY="9" StrokeThickness="1.5" StrokeDashArray="4,3"
                                           Stroke="{ThemeResource TextFillColorTertiaryBrush}" Fill="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                    <FontIcon Glyph="&#xE898;" FontSize="22" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="Drop a video, folder, or link" FontSize="12.5"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- footer -->
                <Grid Grid.Row="1" Height="42" Padding="24,0" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource OkStrokeBrush}"
                      ColumnDefinitions="Auto,*,Auto">
                    <Button Grid.Column="0" Click="OnHistoryClick" Background="Transparent" BorderThickness="0" Padding="2,4"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE81C;" FontSize="13" />
                            <TextBlock Text="History" FontSize="12" FontWeight="Medium" />
                        </StackPanel>
                    </Button>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="{ThemeResource OkOverVideoAccentBrush}" />
                        <TextBlock Text="Recording history" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                    <Button Grid.Column="2" Click="OnSettingsClick" Background="Transparent" BorderThickness="0" Padding="6"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" ToolTipService.ToolTip="Settings">
                        <FontIcon Glyph="&#xE713;" FontSize="15" />
                    </Button>
                </Grid>
            </Grid>
        </Grid>

        <!-- ===== History surface: third idle-canvas state (over Mica), opened from the welcome footer / H ===== -->
        <views:HistoryView x:Name="HistorySurface" Visibility="Collapsed" />

        <!-- ===== top chrome: scrim + title ===== -->
        <Grid x:Name="TitleChrome" VerticalAlignment="Top" Height="42" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="TitleTransform" Y="-10" /></Grid.RenderTransform>
            <Border Background="{StaticResource OkTopScrimBrush}" IsHitTestVisible="False" />
            <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center" Margin="14,0">
                <FontIcon Glyph="&#xE768;" FontSize="13" Foreground="#E6FFFFFF" />
                <TextBlock x:Name="TitleText" Text="{x:Bind Vm.MediaTitle, Mode=OneWay}"
                           Foreground="#F2FFFFFF" FontSize="12.5" FontWeight="Medium" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ===== bottom chrome: scrim + OSC pill ===== -->
        <Grid x:Name="BottomChrome" Opacity="0">
            <Grid.RenderTransform><TranslateTransform x:Name="BottomTransform" Y="16" /></Grid.RenderTransform>

            <!-- bottom scrim -->
            <Border VerticalAlignment="Bottom" Height="220" IsHitTestVisible="False"
                    Background="{StaticResource OkBottomScrimBrush}" />

            <!-- OSC pill — one unified row (play · timeline · time · volume · speed · subs · audio · chapters · shot · fs · …) -->
            <Border VerticalAlignment="Bottom" Margin="16,0,16,18" Padding="18,11" CornerRadius="18"
                    Background="#C8161619" BorderThickness="0,1,0,0" BorderBrush="#24FFFFFF">
                <Border.Shadow><ThemeShadow /></Border.Shadow>
                <Grid ColumnSpacing="16" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /> <!-- play -->
                        <ColumnDefinition Width="Auto" /> <!-- prev -->
                        <ColumnDefinition Width="Auto" /> <!-- next -->
                        <ColumnDefinition Width="Auto" /> <!-- elapsed -->
                        <ColumnDefinition Width="*" />    <!-- seekbar -->
                        <ColumnDefinition Width="Auto" /> <!-- total -->
                        <ColumnDefinition Width="Auto" /> <!-- volume -->
                        <ColumnDefinition Width="Auto" /> <!-- speed -->
                        <ColumnDefinition Width="Auto" /> <!-- subs -->
                        <ColumnDefinition Width="Auto" /> <!-- audio -->
                        <ColumnDefinition Width="Auto" /> <!-- chapters -->
                        <ColumnDefinition Width="Auto" /> <!-- screenshot -->
                        <ColumnDefinition Width="Auto" /> <!-- fullscreen -->
                        <ColumnDefinition Width="Auto" /> <!-- overflow -->
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="PlayButton" Style="{StaticResource OkOscSvgButtonStyle}"
                            Click="OnPlayClick" ToolTipService.ToolTip="Play / Pause (Space)">
                        <FontIcon Glyph="{x:Bind Vm.PlayPauseGlyph, Mode=OneWay}" FontSize="22" Foreground="White" />
                    </Button>
                    <Button Grid.Column="1" Style="{StaticResource OkOscSvgButtonStyle}" Click="OnPrevClick" ToolTipService.ToolTip="Previous chapter">
                        <FontIcon Glyph="&#xE892;" FontSize="17" Foreground="White" />
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource OkOscSvgButtonStyle}" Click="OnNextClick" ToolTipService.ToolTip="Next chapter">
                        <FontIcon Glyph="&#xE893;" FontSize="17" Foreground="White" />
                    </Button>
                    <TextBlock Grid.Column="3" Text="{x:Bind Vm.CurrentTimeText, Mode=OneWay}" VerticalAlignment="Center"
                               MinWidth="54" Foreground="#D9FFFFFF" FontSize="12.5" FontWeight="Medium" Tapped="OnTrailingTimeTapped" />

                    <ctl:SeekBar x:Name="Seek" Grid.Column="4" VerticalAlignment="Center"
                                 Fraction="{x:Bind Vm.PositionFraction, Mode=OneWay}"
                                 Buffered="{x:Bind Vm.BufferedFraction, Mode=OneWay}"
                                 Chapters="{x:Bind Vm.ChapterFractions, Mode=OneWay}"
                                 CurrentChapter="{x:Bind Vm.CurrentChapterIndex, Mode=OneWay}"
                                 AbLoopA="{x:Bind Vm.AbLoopAFraction, Mode=OneWay}"
                                 AbLoopB="{x:Bind Vm.AbLoopBFraction, Mode=OneWay}" />

                    <TextBlock Grid.Column="5" Text="{x:Bind Vm.TrailingTimeText, Mode=OneWay}" VerticalAlignment="Center"
                               MinWidth="62" TextAlignment="Right" Foreground="#D9FFFFFF" FontSize="12.5" FontWeight="Medium"
                               Tapped="OnTrailingTimeTapped" />

                    <!-- volume: mute icon + inline bar + readout (scroll to adjust, click % to type; boost reads amber) -->
                    <!-- volume: resting icon + level wick; hover/focus floats the full slider capsule (design v3) -->
                    <views:VolumeControl x:Name="VolumeCtl" Grid.Column="6" VerticalAlignment="Center" Margin="3,0" />

                    <!-- speed chip -->
                    <Button Grid.Column="7" x:Name="SpeedChip" Style="{StaticResource OkSpeedChipStyle}"
                            Content="{x:Bind Vm.SpeedText, Mode=OneWay}" ToolTipService.ToolTip="Playback speed">
                        <Button.Flyout>
                            <Flyout x:Name="SpeedFlyout" FlyoutPresenterStyle="{StaticResource OkPopoverFlyoutStyle}" Placement="Top">
                                <StackPanel Width="120">
                                    <TextBlock Text="Speed" Style="{StaticResource OkBodyStrongTextStyle}" Margin="6,4" />
                                    <Button Style="{StaticResource OkSwitcherRowStyle}" Tag="0.5"  Content="0.5&#x00D7;"  Click="OnSpeedStepClick" />
                                    <Button Style="{StaticResource OkSwitcherRowStyle}" Tag="0.75" Content="0.75&#x00D7;" Click="OnSpeedStepClick" />
                                    <Button Style="{StaticResource OkSwitcherRowStyle}" Tag="1.0"  Content="1.0&#x00D7;"  Click="OnSpeedStepClick" />
                                    <Button Style="{StaticResource OkSwitcherRowStyle}" Tag="1.25" Content="1.25&#x00D7;" Click="OnSpeedStepClick" />
                                    <Button Style="{StaticResource OkSwitcherRowStyle}" Tag="1.5"  Content="1.5&#x00D7;"  Click="OnSpeedStepClick" />
                                    <Button Style="{StaticResource OkSwitcherRowStyle}" Tag="2.0"  Content="2.0&#x00D7;"  Click="OnSpeedStepClick" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Grid.Column="8" Style="{StaticResource OkOscSvgButtonStyle}" ToolTipService.ToolTip="Subtitles">
                        <FontIcon Glyph="&#xE7F0;" FontSize="19" Foreground="White" />
                        <Button.Flyout>
                            <Flyout x:Name="SubtitleFlyout" FlyoutPresenterStyle="{StaticResource OkPopoverFlyoutStyle}" Placement="Top">
                                <StackPanel Width="272">
                                    <TextBlock Text="Subtitles" Style="{StaticResource OkBodyStrongTextStyle}" Margin="6,4" />
                                    <Button Style="{StaticResource OkSwitcherRowStyle}" Content="Off" Click="OnSubtitleOffClick" />
                                    <ItemsControl ItemsSource="{x:Bind Vm.SubtitleTracks, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:TrackInfo">
                                                <Button Style="{StaticResource OkSwitcherRowStyle}" Content="{x:Bind Label}" Click="OnSubtitleTrackClick" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- Secondary subtitle (a second caption shown at once, top of frame) — only when the file has 2+ tracks -->
                                    <StackPanel Visibility="{x:Bind Vm.SecondarySubtitleVisibility, Mode=OneWay}">
                                        <Border Height="1" Margin="8,4" Background="{ThemeResource OkStrokeBrush}" />
                                        <TextBlock Text="Secondary subtitle" FontSize="11.5" FontWeight="SemiBold" CharacterSpacing="40"
                                                   Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="6,2,6,4" />
                                        <Button Style="{StaticResource OkSwitcherRowStyle}" Content="Off" Click="OnSecondarySubtitleOffClick" />
                                        <ItemsControl ItemsSource="{x:Bind Vm.SecondarySubtitleTracks, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:TrackInfo">
                                                    <Button Style="{StaticResource OkSwitcherRowStyle}" Content="{x:Bind Label}" Click="OnSecondarySubtitleTrackClick" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <Border Height="1" Margin="8,4" Background="{ThemeResource OkStrokeBrush}" />
                                    <Button Style="{StaticResource OkSwitcherRowStyle}" Content="Add subtitle file&#x2026;" Click="OnAddSubtitleFile" />
                                    <Button Style="{StaticResource OkSwitcherRowStyle}" IsEnabled="False"
                                            Foreground="{ThemeResource OkAccentTextBrush}" Content="Generate subtitles&#x2026;  (Scribe)" />
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,6,10,2">
                                        <TextBlock Text="Delay" VerticalAlignment="Center" MinWidth="40" FontSize="12.5" Foreground="{ThemeResource OkTextSecondaryBrush}" />
                                        <Button Style="{StaticResource OkSwitcherRowStyle}" Padding="9,3" FontFamily="Segoe UI" FontSize="14" Content="-" Click="OnSubDelayMinus" />
                                        <TextBlock Text="{x:Bind Vm.SubDelayText, Mode=OneWay}" VerticalAlignment="Center" MinWidth="56" TextAlignment="Center"
                                                   FontSize="12.5" FontWeight="SemiBold" Foreground="{ThemeResource OkAccentTextBrush}" />
                                        <Button Style="{StaticResource OkSwitcherRowStyle}" Padding="9,3" FontFamily="Segoe UI" FontSize="14" Content="+" Click="OnSubDelayPlus" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,2,10,4">
                                        <TextBlock Text="Size" VerticalAlignment="Center" MinWidth="40" FontSize="12.5" Foreground="{ThemeResource OkTextSecondaryBrush}" />
                                        <Button Style="{StaticResource OkSwitcherRowStyle}" Padding="9,3" FontFamily="Segoe UI" FontSize="14" Content="-" Click="OnSubScaleMinus" />
                                        <TextBlock Text="{x:Bind Vm.SubScaleText, Mode=OneWay}" VerticalAlignment="Center" MinWidth="56" TextAlignment="Center"
                                                   FontSize="12.5" FontWeight="SemiBold" Foreground="{ThemeResource OkAccentTextBrush}" />
                                        <Button Style="{StaticResource OkSwitcherRowStyle}" Padding="9,3" FontFamily="Segoe UI" FontSize="14" Content="+" Click="OnSubScalePlus" />
                                    </StackPanel>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Grid.Column="9" Style="{StaticResource OkOscSvgButtonStyle}" ToolTipService.ToolTip="Audio">
                        <FontIcon Glyph="&#xE8D6;" FontSize="19" Foreground="White" />
                        <Button.Flyout>
                            <Flyout x:Name="AudioFlyout" FlyoutPresenterStyle="{StaticResource OkPopoverFlyoutStyle}" Placement="Top"
                                    Opened="OnAudioFlyoutOpened">
                                <StackPanel Width="272">
                                    <TextBlock Text="Audio" Style="{StaticResource OkBodyStrongTextStyle}" Margin="6,4" />
                                    <ItemsControl ItemsSource="{x:Bind Vm.AudioTracks, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:TrackInfo">
                                                <Button Style="{StaticResource OkSwitcherRowStyle}" Content="{x:Bind Label}" Click="OnAudioTrackClick" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border Height="1" Margin="8,4" Background="{ThemeResource OkStrokeBrush}" />
                                    <TextBlock Text="OUTPUT DEVICE" FontSize="11" FontWeight="SemiBold" CharacterSpacing="60"
                                               Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="6,2,6,4" />
                                    <ItemsControl ItemsSource="{x:Bind Vm.AudioDevices, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:AudioDevice">
                                                <Button Style="{StaticResource OkSwitcherRowStyle}" Content="{x:Bind Label}" Click="OnAudioDeviceClick" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Grid.Column="10" x:Name="ChaptersButton" Style="{StaticResource OkOscSvgButtonStyle}"
                            Click="OnChaptersClick" ToolTipService.ToolTip="Chapters (C)">
                        <FontIcon Glyph="&#xE8FD;" FontSize="19" Foreground="White" />
                    </Button>
                    <Button Grid.Column="11" Style="{StaticResource OkOscSvgButtonStyle}" Click="OnScreenshotClick" ToolTipService.ToolTip="Screenshot (S)">
                        <FontIcon Glyph="&#xE722;" FontSize="19" Foreground="White" />
                    </Button>
                    <Button Grid.Column="12" x:Name="FullscreenButton" Style="{StaticResource OkOscSvgButtonStyle}"
                            Click="OnFullscreenClick" ToolTipService.ToolTip="Fullscreen (F)">
                        <FontIcon Glyph="&#xE740;" FontSize="19" Foreground="White" />
                    </Button>
                    <Button Grid.Column="13" Style="{StaticResource OkOscSvgButtonStyle}" ToolTipService.ToolTip="More">
                        <FontIcon Glyph="&#xE712;" FontSize="19" Foreground="White" />
                        <Button.Flyout>
                            <MenuFlyout MenuFlyoutPresenterStyle="{StaticResource OkMenuFlyoutPresenterStyle}">
                                <MenuFlyoutItem Text="Open file&#x2026;" Click="OnOpenFromMenu" />
                                <MenuFlyoutItem Text="Close file" Click="OnCloseFileClick" IsEnabled="{x:Bind Vm.HasMedia, Mode=OneWay}" />
                                <MenuFlyoutItem Text="A&#x2013;B loop" Click="OnAbLoopClick" />
                                <MenuFlyoutItem Text="Fit window to video" Click="OnFitToVideoClick" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Screenshot with subtitles" Click="OnScreenshotWithSubsClick" />
                                <MenuFlyoutItem Text="Copy frame to clipboard" Click="OnCopyFrameClick" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Playlist / Queue" IsEnabled="False" />
                                <MenuFlyoutItem Text="Mini player" Click="OnMiniPlayerClick" IsEnabled="{x:Bind Vm.HasMedia, Mode=OneWay}" />
                                <MenuFlyoutItem Text="Media info&#x2026;" Click="OnMediaInfoClick" />
                                <MenuFlyoutItem Text="Settings&#x2026;" Click="OnSettingsClick" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== seek hover frame-preview (design band 5: frame + timecode + chapter, downward pointer) ===== -->
        <StackPanel x:Name="PreviewPanel" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                    Margin="0,0,0,80" Opacity="0" IsHitTestVisible="False">
            <StackPanel.RenderTransform><TranslateTransform x:Name="PreviewTransform" /></StackPanel.RenderTransform>
            <Border Width="158" CornerRadius="9" Background="#C7121215" BorderThickness="1" BorderBrush="#24FFFFFF">
                <Border.Shadow><ThemeShadow /></Border.Shadow>
                <StackPanel>
                    <Border x:Name="PreviewImageFrame" Height="89" CornerRadius="8,8,0,0"
                            Background="#FF000000" Visibility="Collapsed">
                        <Image x:Name="PreviewImage" Stretch="UniformToFill" />
                    </Border>
                    <StackPanel Padding="9,6">
                        <TextBlock x:Name="PreviewTime" Text="0:00" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                        <TextBlock x:Name="PreviewChapter" FontSize="10" Foreground="#A6FFFFFF" Margin="0,1,0,0"
                                   TextTrimming="CharacterEllipsis" Visibility="Collapsed" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Polygon Points="0,0 12,0 6,6" Fill="#C7121215" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- ===== right-docked Chapters / Up Next panel (slide-in Mica, design band 6) ===== -->
        <!-- inset as a floating card: clear of the window caption buttons (top) and the OSC (bottom), so the
             translucent panel never overlaps those controls (no double-close, no controls bleeding through) -->
        <Grid x:Name="ChaptersPanel" HorizontalAlignment="Right" Width="316" Opacity="0" Visibility="Collapsed"
              Margin="0,44,0,80" CornerRadius="12,0,0,12"
              Background="{ThemeResource OkPanelOverVideoBrush}" BorderThickness="1,1,0,1" BorderBrush="{ThemeResource OkStrokeBrush}"
              RowDefinitions="Auto,Auto,*,Auto">
            <Grid.RenderTransform><TranslateTransform x:Name="PanelTransform" X="316" /></Grid.RenderTransform>

            <!-- segmented header (Chapters | Up Next) + close -->
            <Grid Grid.Row="0" Padding="14,14,8,6" ColumnDefinitions="*,Auto">
                <Border Background="#14000000" CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="ChaptersTab" CornerRadius="6" Tapped="OnChaptersTab">
                            <TextBlock x:Name="ChaptersTabText" Text="Chapters" FontSize="12.5" FontWeight="SemiBold" Padding="16,6" />
                        </Border>
                        <Border x:Name="UpNextTab" CornerRadius="6" Tapped="OnUpNextTab">
                            <TextBlock x:Name="UpNextTabText" Text="Up Next" FontSize="12.5" FontWeight="SemiBold" Padding="16,6" />
                        </Border>
                    </StackPanel>
                </Border>
                <Button Grid.Column="1" Style="{StaticResource OkOscIconButtonStyle}" Content="&#xE711;"
                        Foreground="{ThemeResource OkTextSecondaryBrush}" Click="OnChaptersClick" ToolTipService.ToolTip="Close" />
            </Grid>

            <TextBlock x:Name="ChaptersSectionHeader" Grid.Row="1" Text="CHAPTERS" Margin="20,6,0,4"
                       FontSize="11" FontWeight="SemiBold" CharacterSpacing="60" Foreground="{ThemeResource OkTextSecondaryBrush}" />

            <ListView x:Name="ChapterList" Grid.Row="2" SelectionMode="Single" Padding="8,0"
                      ItemsSource="{x:Bind Vm.Chapters, Mode=OneWay}" SelectionChanged="OnChapterSelectionChanged">
                <ListView.Resources>
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#1F10938A" />
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#2910938A" />
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#2910938A" />
                </ListView.Resources>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChapterInfo">
                        <Grid Padding="0,5" ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="10">
                            <Border Grid.Column="0" Width="3" CornerRadius="2" Height="34"
                                    Background="{ThemeResource OkAccentRailBrush}" Visibility="{x:Bind CurrentBarVisibility, Mode=OneWay}" />
                            <Border Grid.Column="1" Width="56" Height="32" CornerRadius="4" Background="{ThemeResource OkSubtleFillStrongBrush}">
                                <Image Source="{x:Bind Thumbnail, Mode=OneWay}" Stretch="UniformToFill" />
                            </Border>
                            <TextBlock Grid.Column="2" Text="{x:Bind Title}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" Style="{StaticResource OkBodyTextStyle}" />
                            <TextBlock Grid.Column="3" Text="{x:Bind TimeText}" VerticalAlignment="Center" Style="{StaticResource OkSmallTextStyle}" />
                            <!-- rename/delete: only on user-added chapters -->
                            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center"
                                        Visibility="{x:Bind EditVisibility}">
                                <Button Click="OnChapterRename" Content="&#xE70F;" FontFamily="Segoe Fluent Icons" FontSize="12"
                                        Background="Transparent" BorderThickness="0" CornerRadius="6" Padding="7,5"
                                        Foreground="{ThemeResource OkTextSecondaryBrush}" ToolTipService.ToolTip="Rename" />
                                <Button Click="OnChapterDelete" Content="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="11"
                                        Background="Transparent" BorderThickness="0" CornerRadius="6" Padding="7,5"
                                        Foreground="{ThemeResource OkTextSecondaryBrush}" ToolTipService.ToolTip="Delete chapter" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border x:Name="ChaptersFooter" Grid.Row="3" Padding="14,10" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource OkStrokeBrush}">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ChaptersEmpty" Text="No chapters in this file." HorizontalAlignment="Center"
                               Style="{StaticResource OkSmallTextStyle}" />
                    <StackPanel x:Name="BookmarksSection" Spacing="1" Visibility="Collapsed">
                        <TextBlock x:Name="BookmarksHeader" Text="BOOKMARKS" FontSize="11" FontWeight="SemiBold"
                                   CharacterSpacing="60" Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="2,0,0,3" />
                        <ScrollViewer MaxHeight="128" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{x:Bind Bookmarks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BookmarkEntry">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Button Grid.Column="0" Click="OnBookmarkJump" Style="{StaticResource OkSwitcherRowStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="9">
                                                    <FontIcon Glyph="&#xE840;" FontSize="13" Foreground="{ThemeResource OkAccentTextBrush}" />
                                                    <TextBlock Text="{x:Bind TimeText}" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="1" Click="OnBookmarkDelete" Content="&#xE711;" FontFamily="Segoe Fluent Icons"
                                                    FontSize="11" Background="Transparent" BorderThickness="0" CornerRadius="6" Padding="8,6"
                                                    Foreground="{ThemeResource OkTextSecondaryBrush}" VerticalAlignment="Center"
                                                    ToolTipService.ToolTip="Remove bookmark" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                    <Button Click="OnAddChapterClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Background="{ThemeResource OkSubtleFillStrongBrush}" Foreground="{ThemeResource OkTextBodyBrush}" CornerRadius="7" Padding="9"
                            FontSize="12.5" FontWeight="SemiBold" Content="Add chapter here" />
                    <Button Click="OnAddBookmarkClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Background="{ThemeResource OkAccentBrush}" Foreground="White" CornerRadius="7" Padding="9"
                            FontSize="12.5" FontWeight="SemiBold" Content="Bookmark here" />
                </StackPanel>
            </Border>

            <!-- Up Next tab — overlays the Chapters content (rows 1-3); SetPanelTab toggles which shows -->
            <Grid x:Name="UpNextView" Grid.Row="1" Grid.RowSpan="3" Visibility="Collapsed"
                  RowDefinitions="Auto,Auto,*,Auto" Padding="14,6,14,12">
                <!-- now-playing card -->
                <Border Grid.Row="0" CornerRadius="8" Padding="8" Background="{ThemeResource OkAccentSelectionFillBrush}" Margin="0,0,0,10">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Border Grid.Column="0" Width="54" Height="34" CornerRadius="5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                                    <GradientStop Color="#16352B" Offset="0" />
                                    <GradientStop Color="#0C7C75" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <FontIcon Glyph="&#xE768;" FontSize="14" Foreground="#80FFFFFF" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Vm.MediaTitle, Mode=OneWay}" FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{ThemeResource OkAccentTextBrush}" TextTrimming="CharacterEllipsis" MaxLines="1" />
                            <TextBlock Text="NOW PLAYING" FontSize="10.5" FontWeight="SemiBold" CharacterSpacing="40"
                                       Foreground="{ThemeResource OkAccentSecondaryTextBrush}" Margin="0,1,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- FROM THIS FOLDER · N -->
                <TextBlock x:Name="UpNextFolderHeader" Grid.Row="1" Text="FROM THIS FOLDER" FontSize="11" FontWeight="SemiBold"
                           CharacterSpacing="60" Foreground="{ThemeResource OkTextSecondaryBrush}" Margin="2,2,0,5" />
                <!-- the folder, in playlist order -->
                <ScrollViewer x:Name="UpNextList" Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{x:Bind UpNext}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlaylistRow">
                                <Button Click="OnUpNextRowClick" Tag="{x:Bind Path}" Margin="0,0,0,1" Padding="0"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                        Background="Transparent" BorderThickness="0" Opacity="{x:Bind RowOpacity}">
                                    <Grid>
                                        <Border Background="{ThemeResource OkAccentTintBrush}" CornerRadius="6" Visibility="{x:Bind CurrentVisibility}" />
                                        <Grid Padding="7,7" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                            <Grid Grid.Column="0" Width="16" VerticalAlignment="Center">
                                                <Ellipse Width="9" Height="9" Stroke="{ThemeResource OkTextSecondaryBrush}"
                                                         StrokeThickness="1.3" Visibility="{x:Bind CircleVisibility}" />
                                                <FontIcon Glyph="&#xE73E;" FontSize="13" Foreground="{ThemeResource OkAccentSecondaryTextBrush}" Visibility="{x:Bind CheckVisibility}" />
                                            </Grid>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Title}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" Style="{StaticResource OkBodyTextStyle}" />
                                            <Border Grid.Column="2" Visibility="{x:Bind NextVisibility}" Background="{ThemeResource OkAccentSelectionFillBrush}"
                                                    CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                <TextBlock Text="NEXT" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource OkAccentSecondaryTextBrush}" />
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <!-- empty: single URL / lone file -->
                <StackPanel x:Name="UpNextEmpty" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="6" Visibility="Collapsed" Padding="20,0">
                    <FontIcon Glyph="&#xE8A5;" FontSize="24" Foreground="{ThemeResource OkTextSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="Just this file" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"
                               Foreground="{ThemeResource OkTextBodyBrush}" />
                    <TextBlock Text="No other media in this folder." FontSize="11.5" HorizontalAlignment="Center"
                               TextAlignment="Center" Foreground="{ThemeResource OkTextSecondaryBrush}" />
                </StackPanel>

                <!-- footer: play-mode toggles (active = teal accent; SetPanelTab/RefreshModeButtons set colours) -->
                <Border Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource OkStrokeBrush}"
                        Padding="2,8,0,0" Margin="0,8,0,0">
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                            <Button x:Name="RepeatButton" Click="OnRepeatClick" Width="32" Height="32" Padding="0" CornerRadius="7"
                                    Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Repeat (off / all / one)">
                                <FontIcon x:Name="RepeatIcon" Glyph="&#xE8EE;" FontSize="15" Foreground="{ThemeResource OkTextSecondaryBrush}" />
                            </Button>
                            <Button x:Name="ShuffleButton" Click="OnShuffleClick" Width="32" Height="32" Padding="0" CornerRadius="7"
                                    Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Shuffle">
                                <FontIcon x:Name="ShuffleIcon" Glyph="&#xE8B1;" FontSize="15" Foreground="{ThemeResource OkTextSecondaryBrush}" />
                            </Button>
                            <Button x:Name="AutoAdvanceButton" Click="OnAutoAdvanceClick" Width="32" Height="32" Padding="0" CornerRadius="7"
                                    Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Auto-advance (continue to the next file)">
                                <FontIcon x:Name="AutoAdvanceIcon" Glyph="&#xE72C;" FontSize="15" Foreground="{ThemeResource OkTextSecondaryBrush}" />
                            </Button>
                        </StackPanel>
                        <Button Grid.Column="1" Click="OnSavePlaylistClick" CornerRadius="6" Padding="10,5" VerticalAlignment="Center"
                                Background="{ThemeResource OkSubtleFillStrongBrush}" BorderThickness="0"
                                ToolTipService.ToolTip="Save this playlist as an .m3u file">
                            <TextBlock Text="Save .m3u" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource OkTextSecondaryBrush}" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ===== OSD toast (top-center, shared scrim style) ===== -->
        <Border x:Name="ToastHost" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,64,0,0" Padding="14,8" CornerRadius="12" Opacity="0" IsHitTestVisible="False"
                Background="{StaticResource OkOverVideoToastBrush}"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource OkOverVideoHairlineBrush}">
            <Border.RenderTransform><TranslateTransform x:Name="ToastTransform" Y="-8" /></Border.RenderTransform>
            <TextBlock x:Name="ToastText" Foreground="#F2FFFFFF" FontSize="13" FontWeight="Medium" />
        </Border>

        <!-- ===== Media info overlay (design band 13) ===== -->
        <Grid x:Name="MediaInfoHost" Visibility="Collapsed" Background="#52000000">
            <views:MediaInfoCard x:Name="MediaInfoCardView" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <!-- ===== drag-over state: accent drop-zone + dim the rest ===== -->
        <!-- Drag-over feedback: a gentle dim + a single contained "Drop to play" card (no full-window frame,
             so it reads cleanly over the welcome screen as well as over video). -->
        <Grid x:Name="DragOverlay" Visibility="Collapsed" IsHitTestVisible="False">
            <Border Background="#14000000" />
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="14" Padding="34,26"
                    BorderThickness="1.5" BorderBrush="{ThemeResource OkAccentBrush}"
                    Background="{ThemeResource OkSurfaceCardBrush}">
                <StackPanel HorizontalAlignment="Center" Spacing="10">
                    <FontIcon Glyph="&#xE898;" FontSize="28" Foreground="{ThemeResource OkAccentTextBrush}" />
                    <TextBlock Text="Drop to play" FontSize="15" FontWeight="SemiBold"
                               Foreground="{ThemeResource OkAccentTextBrush}" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
