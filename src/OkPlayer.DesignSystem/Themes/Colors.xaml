<?xml version="1.0" encoding="utf-8"?>
<!-- Raw palette seeds (theme-invariant). Brushes.xaml/ScrimBrushes.xaml are the semantic layer;
     these Color resources are here for gradients and code-behind that need a raw Color. -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- OK Teal accent ramp -->
    <Color x:Key="OkTeal700">#FF0A655F</Color>
    <Color x:Key="OkTeal600">#FF0C7C75</Color>
    <Color x:Key="OkTeal500">#FF10938A</Color>
    <Color x:Key="OkTeal400">#FF28B3AA</Color>
    <Color x:Key="OkTealTint">#FFD3EFEC</Color>
    <!-- Dark glyph used on a teal FAB / accent button -->
    <Color x:Key="OkOnAccent">#FF04201E</Color>

    <!-- Light neutrals -->
    <Color x:Key="OkLightMicaBase">#FFF3F3F3</Color>
    <Color x:Key="OkLightLayer1">#FFFBFBFB</Color>
    <Color x:Key="OkLightSurface">#FFFFFFFF</Color>
    <Color x:Key="OkInkHeading">#FF161616</Color>
    <Color x:Key="OkInkBody">#FF1A1A1A</Color>

    <!-- Dark neutrals -->
    <Color x:Key="OkDarkMicaBase">#FF1F1F1F</Color>
    <Color x:Key="OkDarkLayer1">#FF2B2B2B</Color>

    <!-- Over-video constants (same in both themes — the video beneath is theme-agnostic) -->
    <Color x:Key="OkOverVideoFillColor">#80161619</Color>
    <Color x:Key="OkOverVideoToastColor">#99161619</Color>
    <Color x:Key="OkScrimColor">#6B000000</Color>

    <!-- Status -->
    <Color x:Key="OkErrorColor">#FFB42318</Color>
    <Color x:Key="OkErrorOverVideoColor">#FFFF6B5E</Color>

</ResourceDictionary>
