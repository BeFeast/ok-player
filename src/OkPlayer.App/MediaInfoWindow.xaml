<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OkPlayer.App.MediaInfoWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:OkPlayer.App.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Background matches the card so the window's rounded frame corners blend with the card surface. -->
    <Grid Background="#FFF7F7F5">
        <views:MediaInfoCard x:Name="Card" />
        <!-- Transparent drag strip over the card's header so the window moves when dragged there (the card has
             no native title bar). The right inset leaves the OS close button hit-testable; the height stops
             above the tab row so the Streams/Stats tabs stay clickable. -->
        <Grid x:Name="DragRegion" Height="56" VerticalAlignment="Top" Background="Transparent" Margin="0,0,46,0" />
    </Grid>
</Window>
